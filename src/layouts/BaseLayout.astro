---
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  activeSection?: string;
  ogImage?: string;
}

const {
  title = 'Voyadores Design System',
  description = 'Visual identity, components, and guidelines for building consistent Voyadores products.',
  activeSection = '',
  ogImage,
} = Astro.props;

const siteURL    = Astro.site ?? Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL   = ogImage
  ? new URL(ogImage, siteURL).toString()
  : new URL('/images/voyadores-design-system-social.jpg', siteURL).toString();
const ogTitle    = 'Voyadores Design System';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Voyadores</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:site_name"   content="Voyadores Design System" />
    <meta property="og:title"       content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"   content="Voyadores Design System" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/icons/favicon/apple-touch-icon.png" />

    <!-- Urbanist + Chivo Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chivo+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Urbanist:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet" />

    <!-- Voyadores Icon Font -->
    <link rel="stylesheet" href="/fonts/Voyadores-Icon/voyadores-icon.css" />

    <!-- Anti-flash theme init (must be inline, before render) -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('voy-theme') || 'system';
        var dark = t === 'dark' || (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (dark) document.documentElement.setAttribute('data-theme', 'dark');
        document.documentElement.setAttribute('data-color-scheme', t);
      })();
    </script>

    <!-- Page-specific head content -->
    <slot name="head" />
  </head>
  <body>
    <!-- Modern inversion cursor -->
    <div class="c-cursor" id="c-cursor"></div>

    <div class="app-shell">
      <!-- Topbar (mobile) — logo removed; sidebar has the logo at full height -->
      <header class="topbar" id="topbar">
        <button class="ham" id="menu-toggle" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
        <button class="theme-toggle" id="theme-toggle-mobile" aria-label="Toggle theme" title="Toggle theme">
          <svg class="icon-sun"    width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon"   width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-system" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
      </header>

      <div class="overlay" id="sidebar-overlay"></div>

      <Sidebar activeSection={activeSection} />

      <main class="main" id="main">
        <slot />
      </main>

      <!-- Right TOC sidebar -->
      <aside class="r-toc" id="r-toc" aria-label="On this page">
        <div class="toc-label">On this page</div>
        <nav class="toc-nav" id="toc-nav"></nav>
      </aside>
    </div>

    <script>
      /* ── Theme toggle ─────────────────────────────────────────────────── */
      const html    = document.documentElement;
      const toggles = document.querySelectorAll<HTMLButtonElement>('.theme-toggle');
      const mq      = window.matchMedia('(prefers-color-scheme: dark)');

      type Scheme = 'light' | 'dark' | 'system';
      const cycle: Scheme[] = ['light', 'dark', 'system'];

      function applyScheme(scheme: Scheme) {
        const isDark = scheme === 'dark' || (scheme === 'system' && mq.matches);
        if (isDark) html.setAttribute('data-theme', 'dark');
        else        html.removeAttribute('data-theme');
        html.setAttribute('data-color-scheme', scheme);
        localStorage.setItem('voy-theme', scheme);
      }

      // Re-apply system pref on OS change
      mq.addEventListener('change', () => {
        if (html.getAttribute('data-color-scheme') === 'system') applyScheme('system');
      });

      toggles.forEach(btn => {
        btn.addEventListener('click', () => {
          const cur = (html.getAttribute('data-color-scheme') || 'system') as Scheme;
          const next = cycle[(cycle.indexOf(cur) + 1) % cycle.length];
          applyScheme(next);
        });
      });

      /* ── Modern Inversion Cursor ─────────────────────────────────────── */
      const cur = document.getElementById('c-cursor') as HTMLElement;

      if (cur && window.matchMedia('(pointer: fine)').matches) {
        let mx = 0, my = 0, cx = 0, cy = 0;

        const LERP = 0.16;

        document.addEventListener('mousemove', (e: MouseEvent) => {
          mx = e.clientX; my = e.clientY;
        });

        (function tick() {
          cx += (mx - cx) * LERP;
          cy += (my - cy) * LERP;
          cur.style.transform = `translate(${cx}px,${cy}px)`;
          requestAnimationFrame(tick as FrameRequestCallback);
        })();

        document.addEventListener('mouseleave', () => { cur.style.opacity = '0'; });
        document.addEventListener('mouseenter', () => { cur.style.opacity = '1'; });
      }

      /* ── Mobile Sidebar ───────────────────────────────────────────────── */
      const menuBtn = document.getElementById('menu-toggle') as HTMLElement;
      const overlay = document.getElementById('sidebar-overlay') as HTMLElement;
      const sidebar = document.getElementById('sidebar') as HTMLElement;
      const openS  = () => { sidebar.classList.add('open'); overlay.classList.add('show'); document.body.style.overflow='hidden'; menuBtn.classList.add('open'); };
      const closeS = () => { sidebar.classList.remove('open'); overlay.classList.remove('show'); document.body.style.overflow=''; menuBtn.classList.remove('open'); };
      menuBtn.addEventListener('click', () => sidebar.classList.contains('open') ? closeS() : openS());
      overlay.addEventListener('click', closeS);

      /* ── Right TOC ────────────────────────────────────────────────────── */
      (function buildTOC() {
        const main    = document.getElementById('main');
        const toc     = document.getElementById('r-toc');
        const tocNav  = document.getElementById('toc-nav');
        if (!main || !toc || !tocNav) return;

        const headings = Array.from(main.querySelectorAll('h2'));
        if (headings.length < 2) return;

        // Auto-assign IDs
        headings.forEach((h, i) => {
          if (!h.id) {
            const slug = h.textContent!.trim()
              .toLowerCase()
              .replace(/[^a-z0-9\s-]/g, '')
              .replace(/\s+/g, '-')
              .replace(/-+/g, '-')
              .replace(/^-|-$/g, '') || `section-${i}`;
            h.id = slug;
          }
        });

        // Build nav links
        headings.forEach(h => {
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.className = 'toc-link';
          a.textContent = h.textContent!.trim();
          a.addEventListener('click', e => {
            e.preventDefault();
            const target = document.getElementById(h.id);
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          tocNav.appendChild(a);
        });

        toc.classList.add('has-items');
        html.classList.add('has-toc');

        // Scrollspy
        const links = Array.from(tocNav.querySelectorAll<HTMLAnchorElement>('.toc-link'));
        const obs = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            const link = links.find(l => l.getAttribute('href') === '#' + entry.target.id);
            if (link) link.classList.toggle('is-active', entry.isIntersecting);
          });
        }, { rootMargin: '-5% 0px -75% 0px', threshold: 0 });

        headings.forEach(h => obs.observe(h));
      })();
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }



  /* ── Light theme tokens ──────────────────────────────────────────────── */
  :root {
    --brand:   #f7921e;
    --black:   #111111;
    --white:   #ffffff;
    --g1:      #262626;
    --g2:      #7f7f7f;
    --g3:      #c8c8c8;
    --g4:      #e0e0e0;
    --g5:      #ebebeb;
    --g6:      #f6f6f6;
    --font:    "Urbanist", system-ui, -apple-system, sans-serif;
    --mono:    "Chivo Mono", "SFMono-Regular", Consolas, monospace;
    --sidebar: 240px;
    --topbar:  56px;
    --r-toc:   200px;
  }

  /* ── Dark theme tokens ───────────────────────────────────────────────── */
  [data-theme="dark"] {
    --black:  #f0f0f0;
    --white:  #141414;
    --g1:     #e4e4e4;
    --g2:     #888888;
    --g3:     #3c3c3c;
    --g4:     #2e2e2e;
    --g5:     #252525;
    --g6:     #1c1c1c;
  }

  html { height: 100%; scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    font-size: 16px;
    line-height: 1.5;
    color: var(--black);
    background: var(--white);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100%;
    transition: background .25s, color .25s;
  }

  a    { color: inherit; text-decoration: none; }
  img, svg { display: block; max-width: 100%; }
  button { font-family: var(--font); }
  code, pre { font-family: var(--mono); }

  /* ── Global content readability ──────────────────────────────────────── */
  /* Lift small body text across all pages to improve readability */
  p    { font-size: 1rem; line-height: 1.7; }
  li   { font-size: 1rem; line-height: 1.7; }

  /* ── Shared code block ───────────────────────────────────────────────── */
  .code-block { background: #0f0f0f; border-radius: 6px; overflow: auto; border: 1px solid var(--g5); }
  .code-block pre { margin: 0; padding: 20px 24px; }
  .code-block code { font-family: var(--mono); font-size: 13px; color: #e8e8e8; line-height: 1.8; white-space: pre; }

  /* ── Logo visibility (light/dark) ────────────────────────────────────── */
  .logo-dark  { display: none; }
  [data-theme="dark"] .logo-light { display: none; }
  [data-theme="dark"] .logo-dark  { display: block; }

  /* ── Theme toggle icon ───────────────────────────────────────────────── */
  /* Default (light): show sun */
  .icon-moon   { display: none; }
  .icon-system { display: none; }
  /* Dark mode: show moon */
  [data-color-scheme="dark"] .icon-sun    { display: none; }
  [data-color-scheme="dark"] .icon-moon   { display: block; }
  [data-color-scheme="dark"] .icon-system { display: none; }
  /* System mode: show monitor */
  [data-color-scheme="system"] .icon-sun    { display: none; }
  [data-color-scheme="system"] .icon-moon   { display: none; }
  [data-color-scheme="system"] .icon-system { display: block; }

  /* ── Theme toggle label (global — scoped CSS can't target html attrs) ── */
  .label-dark   { display: none; }
  .label-system { display: none; }
  [data-color-scheme="dark"]   .label-light  { display: none; }
  [data-color-scheme="dark"]   .label-dark   { display: inline; }
  [data-color-scheme="dark"]   .label-system { display: none; }
  [data-color-scheme="system"] .label-light  { display: none; }
  [data-color-scheme="system"] .label-dark   { display: none; }
  [data-color-scheme="system"] .label-system { display: inline; }

  /* ── Modern inversion cursor ─────────────────────────────────────────── */
  .c-cursor {
    position: fixed; top: 0; left: 0; z-index: 99999;
    width: 20px; height: 20px;
    background: #fff;
    border-radius: 50%;
    pointer-events: none;
    margin: -10px 0 0 -10px;
    mix-blend-mode: difference;
    transition: width  .3s cubic-bezier(.34,1.56,.64,1),
                height .3s cubic-bezier(.34,1.56,.64,1),
                margin .3s cubic-bezier(.34,1.56,.64,1),
                border-radius .3s ease,
                opacity .2s ease;
    will-change: transform;
  }
  /* Hide on touch devices */
  @media (pointer: coarse) { .c-cursor { display: none; } }

  /* ── Layout shell ────────────────────────────────────────────────────── */
  html, body { overflow-x: hidden; max-width: 100vw; }
  .app-shell { display: flex; min-height: 100vh; overflow-x: hidden; }

  .main {
    flex: 1;
    min-width: 0; /* prevent flex child overflow */
    margin-left: var(--sidebar);
    padding: 80px;
    min-height: 100vh;
    transition: padding-right .2s;
    overflow-x: hidden;
  }

  /* When right TOC is active, give main breathing room */
  html.has-toc .main {
    padding-right: calc(var(--r-toc) + 56px);
  }

  /* ── Topbar (mobile only) ────────────────────────────────────────────── */
  .topbar {
    display: none; position: fixed; top: 0; left: 0; right: 0;
    height: var(--topbar); background: var(--white);
    border-bottom: 1px solid var(--g5);
    align-items: center; justify-content: space-between;
    padding: 0 16px; z-index: 200;
    transition: background .25s, border-color .25s;
  }
  .topbar-logo { display: flex; align-items: center; flex: 1; }
  .ham {
    background: none; border: none; padding: 6px;
    display: flex; flex-direction: column; gap: 5px; flex-shrink: 0;
  }
  .ham span {
    display: block; width: 20px; height: 1.5px;
    background: var(--black); border-radius: 1px;
    transition: .2s ease; transform-origin: center;
  }
  .ham.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .ham.open span:nth-child(2) { opacity: 0; }
  .ham.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .theme-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--g6); border: 1px solid var(--g5);
    color: var(--g1); flex-shrink: 0;
    transition: background .15s, border-color .15s, color .15s;
  }
  .theme-toggle:hover { background: var(--g5); border-color: var(--g4); color: var(--black); }

  .overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.35); backdrop-filter: blur(2px);
    z-index: 149;
  }
  .overlay.show { display: block; }

  /* ── Right TOC ───────────────────────────────────────────────────────── */
  .r-toc {
    position: fixed;
    top: 0; right: 0;
    width: var(--r-toc);
    height: 100vh;
    padding: 88px 24px 40px 8px;
    overflow-y: auto;
    pointer-events: none;
    opacity: 0;
    transition: opacity .25s;
  }
  .r-toc.has-items {
    pointer-events: all;
    opacity: 1;
  }

  .toc-label {
    font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--g2);
    margin-bottom: 12px; padding-bottom: 10px;
    border-bottom: 1px solid var(--g5);
  }

  .toc-nav { display: flex; flex-direction: column; gap: 1px; }

  .toc-link {
    display: block;
    font-size: 13px; font-weight: 500; color: var(--g2);
    line-height: 1.4; padding: 5px 8px;
    border-left: 2px solid transparent; border-radius: 0 3px 3px 0;
    text-decoration: none; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
    transition: color .12s, border-color .12s, background .12s;
  }
  .toc-link:hover { color: var(--black); background: var(--g6); }
  .toc-link.is-active {
    color: var(--brand); font-weight: 600;
    border-left-color: var(--brand);
    background: rgba(247,146,30,.06);
  }

  /* ── Global overflow prevention ─────────────────────────────────────── */
  /* Any element that could be wider than its container scrolls internally */
  table  { display: block; width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  pre    { overflow-x: auto; -webkit-overflow-scrolling: touch; max-width: 100%; }
  img    { max-width: 100%; height: auto; }
  code   { word-break: break-word; }
  /* Grids and flex containers must not exceed their parent */
  * { box-sizing: border-box; }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 1280px) {
    .r-toc { display: none; }
    html.has-toc .main { padding-right: 80px; }
  }
  @media (max-width: 1023px) {
    .main { padding: 56px 40px; }
    html.has-toc .main { padding-right: 40px; }
  }
  @media (max-width: 767px) {
    /* Show topbar, hide sidebar off-screen */
    .topbar { display: flex; }

    /* Content takes full width — sidebar is off-screen until toggled */
    .main {
      margin-left: 0;
      width: 100%;
      max-width: 100vw;
      padding: 20px 16px;
      padding-top: calc(var(--topbar) + 20px);
    }
    html.has-toc .main { padding-right: 16px; }

    /* Touch targets */
    a, button { min-height: 44px; }
    .s-link, .s-sublink, .s-group-header, .s-subgroup-header { min-height: 44px; }

    /* Prevent any wide content causing page scroll */
    .main * { max-width: 100%; }

    /* Tables and code scroll within their container, not the page */
    .main table, .main pre { max-width: calc(100vw - 32px); }
  }
  @media (max-width: 480px) {
    .main { padding: 16px 12px; padding-top: calc(var(--topbar) + 16px); }
    .main table, .main pre { max-width: calc(100vw - 24px); }
  }
</style>
