---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="nf-wrap">

    <div class="nf-illustration">
      <img
        src="/images/states/error/voyadores-404.svg"
        alt="404 — Page not found illustration"
        class="nf-img"
        width="480"
        height="360"
      />
    </div>

    <div class="nf-content">
      <span class="nf-eyebrow">Error 404</span>
      <h1 class="nf-h1">Page not found</h1>
      <p class="nf-body">
        The page you're looking for doesn't exist, has been moved, or the URL may be incorrect.
        Let's get you back on track.
      </p>

      <div class="nf-actions">
        <a href="/" class="nf-btn nf-btn--primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Back to Home
        </a>
        <a href="/introduction" class="nf-btn nf-btn--secondary">View Introduction</a>
      </div>

      <div class="nf-suggestions">
        <p class="nf-suggest-label">Or try one of these</p>
        <div class="nf-links">
          <a href="/color">Color</a>
          <a href="/typography">Typography</a>
          <a href="/icons">Icons</a>
          <a href="/components">Components</a>
          <a href="/resources">Resources</a>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .nf-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    padding: 64px 0 80px;
    min-height: calc(100vh - var(--topbar, 52px) - 120px);
  }

  /* ── Illustration ──────────────────────────────────────────────────── */
  .nf-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nf-img {
    width: 100%;
    max-width: 460px;
    height: auto;
    display: block;
  }

  /* ── Content ───────────────────────────────────────────────────────── */
  .nf-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .nf-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nf-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--brand);
    border-radius: 1px;
  }

  .nf-h1 {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -.8px;
    line-height: 1.1;
    color: var(--black);
    margin-bottom: 16px;
  }

  .nf-body {
    font-size: 15px;
    font-weight: 500;
    color: var(--g2);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 36px;
  }

  /* ── Actions ───────────────────────────────────────────────────────── */
  .nf-actions {
    display: flex;
    gap: 10px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background .15s, color .15s, border-color .15s;
  }

  .nf-btn--primary {
    background: var(--black);
    color: var(--white);
    border: 1px solid var(--black);
  }
  .nf-btn--primary:hover {
    background: var(--brand);
    border-color: var(--brand);
  }

  .nf-btn--secondary {
    background: var(--white);
    color: var(--g1);
    border: 1px solid var(--g4);
  }
  .nf-btn--secondary:hover {
    background: var(--g6);
    border-color: var(--g3);
    color: var(--black);
  }

  /* ── Suggestions ───────────────────────────────────────────────────── */
  .nf-suggestions {
    padding-top: 32px;
    border-top: 1px solid var(--g5);
    width: 100%;
  }

  .nf-suggest-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--g3);
    margin-bottom: 12px;
  }

  .nf-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .nf-links a {
    font-size: 12px;
    font-weight: 600;
    color: var(--g2);
    background: var(--g6);
    border: 1px solid var(--g5);
    padding: 5px 12px;
    border-radius: 100px;
    text-decoration: none;
    transition: color .12s, background .12s, border-color .12s;
  }
  .nf-links a:hover {
    color: var(--brand);
    background: rgba(247,146,30,.06);
    border-color: rgba(247,146,30,.3);
  }

  /* ── Responsive ────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .nf-wrap {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 48px 0 64px;
      text-align: center;
    }

    .nf-illustration { order: -1; }
    .nf-img { max-width: 320px; }

    .nf-content { align-items: center; }

    .nf-eyebrow { justify-content: center; }

    .nf-body { text-align: center; }

    .nf-actions { justify-content: center; }

    .nf-suggestions { text-align: center; }

    .nf-links { justify-content: center; }
  }
</style>
