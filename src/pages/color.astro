---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

// ── Helpers ──────────────────────────────────────────────────────────────────
function lum(hex: string) {
  const n = parseInt(hex.replace('#',''), 16);
  return .2126*((n>>16)&0xff) + .7152*((n>>8)&0xff) + .0722*(n&0xff);
}
function textOn(hex: string) { return lum(hex) > 140 ? '#1a1a1a' : '#ffffff'; }

// ── Semantic tokens ───────────────────────────────────────────────────────────
const semantic = [
  { name: 'Primary',   hex: '#f7921e', v: '--vds-primary',   sub: 'Luminous Orange 500' },
  { name: 'Secondary', hex: '#6a6a6a', v: '--vds-secondary', sub: 'Gray 600'            },
  { name: 'Success',   hex: '#077d55', v: '--vds-success',   sub: 'Green'               },
  { name: 'Info',      hex: '#186ade', v: '--vds-info',      sub: 'Blue'                },
  { name: 'Warning',   hex: '#f5c518', v: '--vds-warning',   sub: 'Yellow'              },
  { name: 'Danger',    hex: '#d91f11', v: '--vds-danger',    sub: 'Red'                 },
];

// ── Color roles (BS 5.3 tonal layers) ────────────────────────────────────────
const colorRoles = [
  { name: 'Primary',   base: '#f7921e', bgSubtle: '#fae1c5', textEmphasis: '#794509', borderSubtle: '#5b3205' },
  { name: 'Secondary', base: '#6a6a6a', bgSubtle: '#e5e5e5', textEmphasis: '#4e4e4e', borderSubtle: '#393939' },
  { name: 'Success',   base: '#077d55', bgSubtle: '#c7ebd1', textEmphasis: '#075e45', borderSubtle: '#094536' },
  { name: 'Danger',    base: '#d91f11', bgSubtle: '#fadcd9', textEmphasis: '#a1160a', borderSubtle: '#75160c' },
  { name: 'Warning',   base: '#f5c518', bgSubtle: '#faf6cf', textEmphasis: '#000000', borderSubtle: '#70491c' },
  { name: 'Info',      base: '#186ade', bgSubtle: '#d4e4fa', textEmphasis: '#0d4ea6', borderSubtle: '#103a75' },
];

// ── Orange scale ──────────────────────────────────────────────────────────────
const orangeScale = [
  { step: '100',  hex: '#fcf3e8', v: '--vds-luminous-orange-100'  },
  { step: '200',  hex: '#fae1c5', v: '--vds-luminous-orange-200'  },
  { step: '300',  hex: '#fcca91', v: '--vds-luminous-orange-300'  },
  { step: '400',  hex: '#f9b361', v: '--vds-luminous-orange-400'  },
  { step: '500',  hex: '#f7921e', v: '--vds-luminous-orange-500', primary: true },
  { step: '600',  hex: '#a35f10', v: '--vds-luminous-orange-600'  },
  { step: '700',  hex: '#794509', v: '--vds-luminous-orange-700'  },
  { step: '800',  hex: '#5b3205', v: '--vds-luminous-orange-800'  },
  { step: '900',  hex: '#432403', v: '--vds-luminous-orange-900'  },
  { step: '1000', hex: '#261201', v: '--vds-luminous-orange-1000' },
];

// ── Gray scale ────────────────────────────────────────────────────────────────
const grayScale = [
  { step: '100',  hex: '#f5f5f5', v: '--vds-gray-100'  },
  { step: '200',  hex: '#e5e5e5', v: '--vds-gray-200'  },
  { step: '300',  hex: '#d5d5d5', v: '--vds-gray-300'  },
  { step: '400',  hex: '#a4a4a4', v: '--vds-gray-400'  },
  { step: '500',  hex: '#888888', v: '--vds-gray-500'  },
  { step: '600',  hex: '#6a6a6a', v: '--vds-gray-600'  },
  { step: '700',  hex: '#4e4e4e', v: '--vds-gray-700'  },
  { step: '800',  hex: '#393939', v: '--vds-gray-800'  },
  { step: '900',  hex: '#272727', v: '--vds-gray-900'  },
  { step: '1000', hex: '#161616', v: '--vds-gray-1000' },
];

// ── Extended palette ──────────────────────────────────────────────────────────
const extended = [
  { name: 'Blue',   hex: '#186ade', v: '--vds-blue'   },
  { name: 'Indigo', hex: '#545fe8', v: '--vds-indigo' },
  { name: 'Purple', hex: '#8f49de', v: '--vds-purple' },
  { name: 'Pink',   hex: '#cc1d92', v: '--vds-pink'   },
  { name: 'Red',    hex: '#d91f11', v: '--vds-red'    },
  { name: 'Orange', hex: '#e86427', v: '--vds-orange' },
  { name: 'Yellow', hex: '#f5c518', v: '--vds-yellow' },
  { name: 'Green',  hex: '#077d55', v: '--vds-green'  },
  { name: 'Teal',   hex: '#167b7d', v: '--vds-teal'   },
  { name: 'Cyan',   hex: '#067a91', v: '--vds-cyan'   },
];

// ── Surface / body tokens ─────────────────────────────────────────────────────
const surfaces = [
  { name: 'Body BG',        hex: '#ffffff',  v: '--vds-body-bg',        desc: 'Page background'           },
  { name: 'Secondary BG',   hex: '#f5f5f5',  v: '--vds-secondary-bg',   desc: 'Cards, inputs, panels'     },
  { name: 'Tertiary BG',    hex: '#f4f4f5',  v: '--vds-tertiary-bg',    desc: 'Subtle section fills'      },
  { name: 'Border',         hex: '#e4e4e7',  v: '--vds-border-color',   desc: 'Default dividers'          },
  { name: 'Body Text',      hex: '#272727',  v: '--vds-body-color',     desc: 'Default paragraph text'   },
  { name: 'Secondary Text', hex: '#4e4e4e',  v: '--vds-secondary-color',desc: 'Muted / supporting text'  },
  { name: 'Tertiary Text',  hex: '#a4a4a4',  v: '--vds-tertiary-color', desc: 'Placeholder, disabled'    },
  { name: 'Emphasis',       hex: '#000000',  v: '--vds-emphasis-color', desc: 'High-contrast headings'   },
];
---

<BaseLayout title="Color" activeSection="color">
  <PageHeader
    eyebrow="Color"
    title="Color Palette"
    description="All color tokens defined as CSS custom properties (--vds-*) on :root. The VDS theme extends Bootstrap 5.3 with semantic roles, subtle tonal layers, emphasis text, and adaptive surface colors."
  />

  <!-- ── 1. Semantic Colors ──────────────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Semantic Colors</h2>
      <p class="sec-desc">Core tokens for interactive elements, alerts, and status indicators. Applied via Bootstrap utility classes and VDS CSS variables.</p>
    </div>
    <div class="semantic-grid">
      {semantic.map(s => (
        <div class="sem-card">
          <div class="sem-swatch" style={`background:${s.hex}`}>
            <span class="sem-hex" style={`color:${textOn(s.hex)}`}>{s.hex}</span>
          </div>
          <div class="sem-body">
            <span class="sem-name">{s.name}</span>
            <span class="sem-sub">{s.sub}</span>
            <span class="sem-var">{s.v}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 2. Luminous Orange scale ───────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Luminous Orange <span class="primary-chip">Brand Primary</span></h2>
      <p class="sec-desc">The VDS signature color. 500 is the primary brand token. Lighter steps for backgrounds and tints, darker for text and borders.</p>
    </div>
    <div class="scale-strip">
      {orangeScale.map(s => (
        <div class="strip-step" style={`background:${s.hex}`} title={`${s.step}: ${s.hex}`}>
          {s.primary && <span class="strip-marker">↑ 500</span>}
        </div>
      ))}
    </div>
    <div class="scale-grid">
      {orangeScale.map(s => (
        <div class:list={['sc', s.primary ? 'sc--primary' : '']}>
          <div class="sc-swatch" style={`background:${s.hex}`}></div>
          <span class="sc-step">{s.step}</span>
          <span class="sc-hex">{s.hex}</span>
          <span class="sc-var">{s.v}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 3. Gray scale ──────────────────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Gray Scale</h2>
      <p class="sec-desc">Ten-step neutral ramp used for surfaces, borders, secondary text, and disabled states.</p>
    </div>
    <div class="scale-strip">
      {grayScale.map(s => (
        <div class="strip-step" style={`background:${s.hex}`} title={`${s.step}: ${s.hex}`}></div>
      ))}
    </div>
    <div class="scale-grid">
      {grayScale.map(s => (
        <div class="sc">
          <div class="sc-swatch" style={`background:${s.hex}`}></div>
          <span class="sc-step">{s.step}</span>
          <span class="sc-hex">{s.hex}</span>
          <span class="sc-var">{s.v}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 4. Extended palette ────────────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Extended Palette</h2>
      <p class="sec-desc">Raw VDS color primitives. Use semantic tokens in components — reserve these for data visualizations, illustrations, and custom patterns.</p>
    </div>
    <div class="ext-grid">
      {extended.map(s => (
        <div class="ext-card">
          <div class="ext-swatch" style={`background:${s.hex}`}>
            <span class="ext-hex-on" style={`color:${textOn(s.hex)}`}>{s.hex}</span>
          </div>
          <div class="ext-body">
            <span class="ext-name">{s.name}</span>
            <span class="ext-var">{s.v}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 5. Color Roles (BS 5.3 tonal layers) ──────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Color Roles <span class="bs-badge">Bootstrap 5.3</span></h2>
      <p class="sec-desc">Each semantic color has three tonal layers — a light background, an accessible text shade, and a dark border — enabling on-brand UI without extra CSS.</p>
    </div>
    <div class="roles-table">
      <div class="roles-thead">
        <span>Color</span>
        <span>Base</span>
        <span>bg-subtle</span>
        <span>text-emphasis</span>
        <span>border-subtle</span>
        <span>Example</span>
      </div>
      {colorRoles.map(c => (
        <div class="roles-row">
          <span class="roles-name">{c.name}</span>
          <span class="roles-swatch-cell">
            <span class="roles-dot" style={`background:${c.base}`}></span>
            <span class="roles-hex">{c.base}</span>
          </span>
          <span class="roles-swatch-cell">
            <span class="roles-dot" style={`background:${c.bgSubtle};border:1px solid rgba(0,0,0,.08)`}></span>
            <span class="roles-hex">{c.bgSubtle}</span>
          </span>
          <span class="roles-swatch-cell">
            <span class="roles-dot" style={`background:${c.textEmphasis}`}></span>
            <span class="roles-hex">{c.textEmphasis}</span>
          </span>
          <span class="roles-swatch-cell">
            <span class="roles-dot" style={`background:${c.borderSubtle}`}></span>
            <span class="roles-hex">{c.borderSubtle}</span>
          </span>
          <span class="roles-example-cell">
            <span
              class={`roles-chip bg-${c.name.toLowerCase()}-subtle text-${c.name.toLowerCase()}-emphasis`}
              style={`background:${c.bgSubtle};color:${c.textEmphasis};border:1px solid ${c.borderSubtle}30`}
            >
              {c.name}
            </span>
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 6. Surface & Body tokens ───────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Surface &amp; Body <span class="bs-badge">Bootstrap 5.3</span></h2>
      <p class="sec-desc">Layered background and text hierarchy tokens. All values adapt automatically when <code>data-bs-theme="dark"</code> is applied.</p>
    </div>
    <div class="surface-grid">
      {surfaces.map(s => (
        <div class="sf-card">
          <div class="sf-swatch" style={`background:${s.hex};outline:1px solid rgba(0,0,0,.08);outline-offset:-1px`}>
            <span class="sf-hex-on" style={`color:${textOn(s.hex)};mix-blend-mode:${lum(s.hex)>180 ? 'multiply' : 'normal'}`}>{s.hex}</span>
          </div>
          <div class="sf-body">
            <span class="sf-name">{s.name}</span>
            <span class="sf-desc">{s.desc}</span>
            <span class="sf-var">{s.v}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 7. Dark Mode ───────────────────────────────────────────────────── -->
  <section class="sec">
    <div class="sec-hd">
      <h2 class="sec-title">Dark Mode</h2>
      <p class="sec-desc">Add <code>data-bs-theme="dark"</code> to any element. All semantic, tonal, and surface tokens are re-mapped — no extra CSS needed.</p>
    </div>
    <div class="dark-panel">
      <div class="dark-panel-header">
        <code class="dark-attr">data-bs-theme="dark"</code>
      </div>
      <div class="dark-panel-body">

        <!-- Semantic -->
        <div class="dark-col">
          <p class="dark-col-label">Semantic</p>
          <div class="dark-tokens">
            {[
              { label: 'Primary',   hex: '#f9b361' },
              { label: 'Secondary', hex: '#888888' },
              { label: 'Success',   hex: '#16a163' },
              { label: 'Info',      hex: '#3d8df5' },
              { label: 'Warning',   hex: '#f5c518' },
              { label: 'Danger',    hex: '#fa5343' },
            ].map(t => (
              <div class="dtk">
                <div class="dtk-dot" style={`background:${t.hex}`}></div>
                <div class="dtk-info">
                  <span class="dtk-label">{t.label}</span>
                  <span class="dtk-hex">{t.hex}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Subtle backgrounds -->
        <div class="dark-col">
          <p class="dark-col-label">bg-subtle</p>
          <div class="dark-tokens">
            {[
              { label: 'primary',   hex: '#5b3205' },
              { label: 'secondary', hex: '#393939' },
              { label: 'success',   hex: '#094536' },
              { label: 'info',      hex: '#103a75' },
              { label: 'warning',   hex: '#b3870e' },
              { label: 'danger',    hex: '#75160c' },
            ].map(t => (
              <div class="dtk">
                <div class="dtk-dot" style={`background:${t.hex};border:1px solid rgba(255,255,255,.12)`}></div>
                <div class="dtk-info">
                  <span class="dtk-label">{t.label}-bg-subtle</span>
                  <span class="dtk-hex">{t.hex}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Surfaces -->
        <div class="dark-col">
          <p class="dark-col-label">Surfaces</p>
          <div class="dark-tokens">
            {[
              { label: 'body-bg',         hex: '#161616' },
              { label: 'secondary-bg',    hex: '#272727' },
              { label: 'tertiary-bg',     hex: '#393939' },
              { label: 'border-color',    hex: '#27272a' },
              { label: 'body-color',      hex: '#f5f5f5' },
              { label: 'secondary-color', hex: '#d5d5d5' },
            ].map(t => (
              <div class="dtk">
                <div class="dtk-dot" style={`background:${t.hex};border:1px solid rgba(255,255,255,.12)`}></div>
                <div class="dtk-info">
                  <span class="dtk-label">{t.label}</span>
                  <span class="dtk-hex">{t.hex}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Layout ─────────────────────────────────────────────────────────────── */
  .sec { margin-bottom: 80px; }
  .sec-hd { margin-bottom: 28px; }
  .sec-title {
    font-size: 18px; font-weight: 600; letter-spacing: -.3px;
    color: var(--black); margin: 0 0 8px;
    display: flex; align-items: center; gap: 10px;
  }
  .sec-desc {
    font-size: 13px; color: var(--g2); line-height: 1.7;
    max-width: 600px; margin: 0;
  }
  .sec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px; color: var(--g1);
  }

  /* ── Labels ─────────────────────────────────────────────────────────────── */
  .bs-badge {
    font-size: 10px; font-weight: 600; font-family: var(--mono);
    color: #186ade; background: #d4e4fa;
    border-radius: 100px; padding: 2px 8px; letter-spacing: .02em;
  }
  .primary-chip {
    font-size: 11px; font-weight: 600; color: var(--brand);
    background: rgba(247,146,30,.1); border: 1px solid rgba(247,146,30,.3);
    border-radius: 100px; padding: 2px 10px;
  }

  /* ── 1. Semantic grid ───────────────────────────────────────────────────── */
  .semantic-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
  .sem-card { border: 1px solid var(--g5); border-radius: 6px; overflow: hidden; }
  .sem-swatch {
    height: 88px; position: relative;
    display: flex; align-items: flex-end; padding: 8px 10px;
  }
  .sem-hex { font-size: 10px; font-family: var(--mono); font-weight: 500; opacity: .85; }
  .sem-body { padding: 10px 10px 12px; display: flex; flex-direction: column; gap: 2px; }
  .sem-name { font-size: 13px; font-weight: 600; color: var(--black); }
  .sem-sub  { font-size: 11px; color: var(--g3); }
  .sem-var  { font-size: 10px; font-family: var(--mono); color: var(--g3); margin-top: 2px; }

  /* ── 2 & 3. Scale strip + grid ──────────────────────────────────────────── */
  .scale-strip {
    display: flex; height: 12px; border-radius: 6px; overflow: hidden;
    margin-bottom: 16px; gap: 2px;
  }
  .strip-step {
    flex: 1; position: relative; border-radius: 2px;
  }
  .strip-marker {
    position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%);
    font-size: 9px; font-family: var(--mono); color: var(--brand);
    white-space: nowrap;
  }
  .scale-grid {
    display: grid; grid-template-columns: repeat(10, 1fr); gap: 6px;
    margin-top: 6px;
  }
  .sc { display: flex; flex-direction: column; }
  .sc--primary .sc-swatch { outline: 2px solid var(--brand); outline-offset: 2px; }
  .sc-swatch {
    height: 52px; border-radius: 4px; margin-bottom: 7px;
    border: 1px solid var(--g5);
  }
  .sc-step { font-size: 11px; font-weight: 700; color: var(--black); }
  .sc-hex  { font-size: 10px; font-family: var(--mono); color: var(--g2); }
  .sc-var  { font-size: 9px;  font-family: var(--mono); color: var(--g4); margin-top: 1px; display: none; }

  /* ── 4. Extended palette ────────────────────────────────────────────────── */
  .ext-grid { display: grid; grid-template-columns: repeat(10, 1fr); gap: 6px; }
  .ext-card { border: 1px solid var(--g5); border-radius: 6px; overflow: hidden; }
  .ext-swatch {
    height: 68px; display: flex; align-items: flex-end; padding: 6px 8px;
  }
  .ext-hex-on { font-size: 9px; font-family: var(--mono); font-weight: 500; opacity: .8; }
  .ext-body { padding: 8px 8px 10px; display: flex; flex-direction: column; gap: 1px; }
  .ext-name { font-size: 12px; font-weight: 600; color: var(--black); }
  .ext-var  { font-size: 9px;  font-family: var(--mono); color: var(--g3); }

  /* ── 5. Color Roles table ───────────────────────────────────────────────── */
  .roles-table { border: 1px solid var(--g5); border-radius: 6px; overflow: hidden; }
  .roles-thead {
    display: grid;
    grid-template-columns: 90px 1fr 1fr 1fr 1fr 100px;
    gap: 0;
    background: var(--g6); border-bottom: 1px solid var(--g5);
    padding: 0;
  }
  .roles-thead > span {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .07em; color: var(--g3);
    padding: 10px 14px;
  }
  .roles-row {
    display: grid;
    grid-template-columns: 90px 1fr 1fr 1fr 1fr 100px;
    align-items: center;
    border-top: 1px solid var(--g5);
    padding: 0;
  }
  .roles-row:first-of-type { border-top: none; }
  .roles-name {
    font-size: 13px; font-weight: 600; color: var(--black);
    padding: 12px 14px;
  }
  .roles-swatch-cell {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 14px;
  }
  .roles-dot {
    width: 22px; height: 22px; border-radius: 4px; flex-shrink: 0;
  }
  .roles-hex { font-size: 11px; font-family: var(--mono); color: var(--g2); }
  .roles-example-cell { padding: 12px 14px; }
  .roles-chip {
    display: inline-block;
    font-size: 11px; font-weight: 600; font-family: var(--mono);
    padding: 3px 10px; border-radius: 100px;
  }

  /* ── 6. Surface grid ────────────────────────────────────────────────────── */
  .surface-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .sf-card { border: 1px solid var(--g5); border-radius: 6px; overflow: hidden; }
  .sf-swatch {
    height: 64px; display: flex; align-items: flex-end; padding: 8px 10px;
  }
  .sf-hex-on { font-size: 10px; font-family: var(--mono); font-weight: 500; opacity: .8; }
  .sf-body { padding: 10px 12px 12px; display: flex; flex-direction: column; gap: 2px; }
  .sf-name { font-size: 12px; font-weight: 600; color: var(--black); }
  .sf-desc { font-size: 11px; color: var(--g3); }
  .sf-var  { font-size: 10px; font-family: var(--mono); color: var(--g4); margin-top: 2px; }

  /* ── 7. Dark mode panel ─────────────────────────────────────────────────── */
  .dark-panel { background: #111; border-radius: 8px; overflow: hidden; }
  .dark-panel-header {
    padding: 14px 24px; border-bottom: 1px solid #222;
    background: #0a0a0a;
  }
  .dark-attr {
    font-family: var(--mono); font-size: 12px; font-weight: 500;
    color: #fcca91;
  }
  .dark-panel-body {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .dark-col {
    padding: 20px 24px; border-right: 1px solid #1e1e1e;
  }
  .dark-col:last-child { border-right: none; }
  .dark-col-label {
