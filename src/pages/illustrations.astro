---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const CDN = 'https://cdn.voyadores.com/content';

function getFilesRecursive(dir: string): string[] {
  const result: string[] = [];
  try {
    const entries = fs.readdirSync(dir, { withFileTypes: true });
    for (const entry of entries) {
      const fullPath = path.join(dir, entry.name);
      if (entry.isDirectory()) result.push(...getFilesRecursive(fullPath));
      else result.push(fullPath);
    }
  } catch {}
  return result;
}

const publicBase = path.resolve(process.cwd(), 'public');
const imgBase = path.join(publicBase, 'images');

// Illustrations
const illustrationFiles = getFilesRecursive(path.join(imgBase, 'illustrations'))
  .map(f => f.replace(publicBase + path.sep, '').replace(/\\/g, '/'));

// States — grouped by direct subfolder
const statesDir = path.join(imgBase, 'states');
const stateSubfolders = ['alert', 'empty', 'error', 'loader', 'maintenance', 'public'];
const stateGroups = stateSubfolders.map(sub => {
  const files = getFilesRecursive(path.join(statesDir, sub))
    .map(f => f.replace(publicBase + path.sep, '').replace(/\\/g, '/'));
  const label = sub.charAt(0).toUpperCase() + sub.slice(1);
  return { name: sub, label, files };
}).filter(g => g.files.length > 0);

const totalFiles = illustrationFiles.length + stateGroups.reduce((n, g) => n + g.files.length, 0);
---

<BaseLayout title="Illustrations">
  <PageHeader
    eyebrow="Content & Resources"
    title="Illustrations"
    description={`${totalFiles} images across illustrations and UI state sets. Click any image to preview and copy its CDN URL.`}
  />

  <!-- Search -->
  <div class="filter-bar">
    <div class="search-wrap">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="searchInput" placeholder="Filter by filename…" autocomplete="off" />
    </div>
  </div>

  <!-- Illustrations -->
  <section class="sec" data-section="illustrations">
    <h2 class="sec-heading">
      Illustrations
      <span class="sec-count">{illustrationFiles.length}</span>
    </h2>
    <div class="img-grid">
      {illustrationFiles.map(filePath => {
        const filename = filePath.split('/').pop()!;
        return (
          <button
            class="img-card"
            data-name={filename.toLowerCase()}
            data-local={'/' + filePath}
            data-cdn={`${CDN}/${filePath}`}
            data-filename={filename}
            data-filepath={filePath}
          >
            <div class="img-thumb">
              <img src={'/' + filePath} alt={filename} loading="lazy" />
            </div>
            <div class="img-label">{filename}</div>
          </button>
        );
      })}
    </div>
  </section>

  <!-- States -->
  {stateGroups.map(group => (
    <section class="sec" data-section={`states-${group.name}`}>
      <h2 class="sec-heading">
        {group.label} States
        <span class="sec-count">{group.files.length}</span>
      </h2>
      <div class="img-grid">
        {group.files.map(filePath => {
          const filename = filePath.split('/').pop()!;
          return (
            <button
              class="img-card"
              data-name={filename.toLowerCase()}
              data-local={'/' + filePath}
              data-cdn={`${CDN}/${filePath}`}
              data-filename={filename}
              data-filepath={filePath}
            >
              <div class="img-thumb">
                <img src={'/' + filePath} alt={filename} loading="lazy" />
              </div>
              <div class="img-label">{filename}</div>
            </button>
          );
        })}
      </div>
    </section>
  ))}

  <p class="no-results" id="noResults" style="display:none">No files match your filter.</p>
</BaseLayout>

<!-- Popover -->
<div class="pop-backdrop" id="popBackdrop" aria-hidden="true">
  <div class="pop" role="dialog" aria-modal="true" aria-label="Image preview">
    <button class="pop-close" id="popClose" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="pop-preview">
      <img id="popImg" src="" alt="" />
    </div>

    <div class="pop-body">
      <div class="pop-filename" id="popFilename"></div>
      <div class="pop-path" id="popPath"></div>

      <div class="pop-url-row">
        <code class="pop-url" id="popUrl"></code>
      </div>

      <div class="pop-actions">
        <button class="pop-btn pop-btn--primary" id="popCopy">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          Copy CDN URL
        </button>
        <a class="pop-btn pop-btn--secondary" id="popDownload" href="" download="">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  // ── Popover ────────────────────────────────────────────────────────────────
  var backdrop   = document.getElementById('popBackdrop');
  var popImg     = document.getElementById('popImg');
  var popFilename = document.getElementById('popFilename');
  var popPath    = document.getElementById('popPath');
  var popUrl     = document.getElementById('popUrl');
  var popCopy    = document.getElementById('popCopy');
  var popDl      = document.getElementById('popDownload');
  var popClose   = document.getElementById('popClose');

  function openPop(card) {
    var local    = card.dataset.local;
    var cdn      = card.dataset.cdn;
    var filename = card.dataset.filename;
    var filepath = card.dataset.filepath;

    popImg.src        = local;
    popImg.alt        = filename;
    popFilename.textContent = filename;
    popPath.textContent     = filepath;
    popUrl.textContent      = cdn;
    popCopy.dataset.cdn     = cdn;
    popDl.href              = local;
    popDl.download          = filename;

    backdrop.classList.add('is-open');
    backdrop.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    popClose.focus();
  }

  function closePop() {
    backdrop.classList.remove('is-open');
    backdrop.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Open on card click
  document.addEventListener('click', function (e) {
    var card = e.target.closest('.img-card');
    if (card) { openPop(card); return; }
  });

  // Close on backdrop click
  backdrop.addEventListener('click', function (e) {
    if (e.target === backdrop) closePop();
  });

  // Close button
  popClose.addEventListener('click', closePop);

  // Escape key
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && backdrop.classList.contains('is-open')) closePop();
  });

  // Copy CDN URL
  popCopy.addEventListener('click', function () {
    var url = popCopy.dataset.cdn;
    navigator.clipboard.writeText(url).then(function () {
      var orig = popCopy.innerHTML;
      popCopy.textContent = 'Copied!';
      setTimeout(function () { popCopy.innerHTML = orig; }, 1500);
    });
  });

  // ── Search ─────────────────────────────────────────────────────────────────
  var searchInput = document.getElementById('searchInput');
  var noResults   = document.getElementById('noResults');

  searchInput.addEventListener('input', function () {
    var q = this.value.toLowerCase().trim();
    var anyVisible = false;

    document.querySelectorAll('.img-card').forEach(function (el) {
      var match = !q || el.dataset.name.includes(q);
      el.style.display = match ? '' : 'none';
      if (match) anyVisible = true;
    });

    document.querySelectorAll('[data-section]').forEach(function (sec) {
      var hasVisible = Array.from(sec.querySelectorAll('.img-card')).some(function (el) {
        return el.style.display !== 'none';
      });
      sec.style.display = hasVisible ? '' : 'none';
    });

    noResults.style.display = anyVisible ? 'none' : 'block';
  });
})();
</script>

<style>
  .filter-bar { margin-bottom: 40px; }
  .search-wrap { position: relative; max-width: 440px; }
  .search-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    pointer-events: none;
  }
  #searchInput {
    width: 100%; padding: 9px 12px 9px 36px;
    font-family: var(--font); font-size: 13px; color: var(--black);
    border: 1px solid var(--g5); border-radius: 4px;
    background: var(--white); outline: none; transition: border-color .12s;
  }
  #searchInput:focus { border-color: var(--brand); }
  #searchInput::placeholder { color: var(--g2); }
  .search-icon { color: var(--g2); }

  .sec { margin-bottom: 64px; }

  .sec-heading {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--g2); margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--g5);
  }
  .sec-count {
    font-size: 10px; font-weight: 700; font-family: var(--mono);
    background: var(--g6); border: 1px solid var(--g5);
    padding: 2px 8px; border-radius: 100px; color: var(--g2);
  }

  /* ── Shared thumbnail grid ───────────────────────────────────────────────── */
  .img-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 8px;
  }

  .img-card {
    display: flex; flex-direction: column;
    background: var(--white); border: 1px solid var(--g5); border-radius: 6px;
    overflow: hidden; cursor: pointer; text-align: left; padding: 0;
    transition: border-color .15s, box-shadow .15s;
  }
  .img-card:hover {
    border-color: var(--brand);
    box-shadow: 0 2px 12px rgba(247,146,30,.1);
  }

  .img-thumb {
    width: 100%; aspect-ratio: 4/3;
    background: var(--g6); border-bottom: 1px solid var(--g5);
    display: flex; align-items: center; justify-content: center;
    padding: 16px; box-sizing: border-box;
  }
  .img-thumb img {
    max-width: 100%; max-height: 100%;
    object-fit: contain; display: block;
  }

  .img-label {
    padding: 8px 10px;
    font-size: 10px; font-family: var(--mono); color: var(--g2);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: color .12s;
  }
  .img-card:hover .img-label { color: var(--brand); }

  .no-results { text-align: center; font-size: 13px; color: var(--g2); padding: 48px 0; }

  /* ── Popover ─────────────────────────────────────────────────────────────── */
  .pop-backdrop {
    position: fixed; inset: 0; z-index: 900;
    background: rgba(0,0,0,.55);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    opacity: 0; pointer-events: none;
    transition: opacity .2s;
  }
  .pop-backdrop.is-open {
    opacity: 1; pointer-events: all;
  }

  .pop {
    position: relative;
    background: var(--white); border-radius: 10px;
    box-shadow: 0 24px 64px rgba(0,0,0,.2);
    width: 100%; max-width: 520px;
    display: flex; flex-direction: column;
    overflow: hidden;
    transform: scale(.96);
    transition: transform .2s cubic-bezier(.34,1.56,.64,1);
  }
  .pop-backdrop.is-open .pop { transform: scale(1); }

  .pop-close {
    position: absolute; top: 12px; right: 12px; z-index: 2;
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(0,0,0,.06); border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--g1);
    transition: background .12s, color .12s;
  }
  .pop-close:hover { background: rgba(0,0,0,.14); color: var(--black); }

  .pop-preview {
    background: var(--g6); border-bottom: 1px solid var(--g5);
    display: flex; align-items: center; justify-content: center;
    min-height: 220px; max-height: 320px; padding: 32px;
    overflow: hidden;
  }
  .pop-preview img {
    max-width: 100%; max-height: 260px;
    object-fit: contain; display: block;
  }

  .pop-body { padding: 20px 22px 22px; }

  .pop-filename {
    font-size: 14px; font-weight: 700; color: var(--black);
    margin-bottom: 2px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .pop-path {
    font-size: 11px; font-family: var(--mono); color: var(--g3);
    margin-bottom: 16px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .pop-url-row {
    background: var(--g6); border: 1px solid var(--g5); border-radius: 4px;
    padding: 10px 12px; margin-bottom: 14px; overflow: hidden;
  }
  .pop-url {
    font-family: var(--mono); font-size: 11px; color: var(--g1);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    display: block;
  }

  .pop-actions { display: flex; gap: 8px; }

  .pop-btn {
    display: inline-flex; align-items: center; gap: 7px; flex: 1;
    justify-content: center;
    font-family: var(--font); font-size: 13px; font-weight: 600;
    padding: 10px 16px; border-radius: 6px;
    cursor: pointer; text-decoration: none; border: none;
    transition: background .12s, color .12s, border-color .12s;
    white-space: nowrap;
  }
  .pop-btn--primary {
    background: var(--brand); color: var(--white);
  }
  .pop-btn--primary:hover { background: #e0831a; }

  .pop-btn--secondary {
    background: var(--white); color: var(--black);
    border: 1px solid var(--g4);
  }
  .pop-btn--secondary:hover { border-color: var(--g2); background: var(--g6); }

  @media (max-width: 640px) {
    .img-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
    .pop-preview { min-height: 160px; max-height: 220px; padding: 20px; }
    .pop-actions { flex-direction: column; }
  }
</style>
