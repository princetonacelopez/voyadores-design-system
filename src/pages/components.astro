---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const bootstrapComponents = [
  { label: 'Buttons',       href: '/components/bootstrap/buttons',      desc: 'Solid, outline, link, ghost, and size variants.'             },
  { label: 'Button Group',  href: '/components/bootstrap/button-group', desc: 'Horizontal & vertical button toolbars.'                     },
  { label: 'Badges',        href: '/components/bootstrap/badges',       desc: 'Small count or label chips with color variants.'            },
  { label: 'Alerts',        href: '/components/bootstrap/alerts',       desc: 'Contextual feedback messages, dismissible.'                  },
  { label: 'Cards',         href: '/components/bootstrap/cards',        desc: 'Flexible content containers with headers and images.'       },
  { label: 'Tables',        href: '/components/bootstrap/tables',       desc: 'Responsive, striped, hover, and bordered tables.'           },
  { label: 'List Group',    href: '/components/bootstrap/list-group',   desc: 'Flexible list items with active and disabled states.'       },
  { label: 'Forms',         href: '/components/bootstrap/forms',        desc: 'Inputs, selects, checkboxes, radios, switches, and ranges.' },
  { label: 'Input Group',   href: '/components/bootstrap/input-group',  desc: 'Text addons attached to form inputs.'                       },
  { label: 'Validation',    href: '/components/bootstrap/validation',   desc: 'Valid and invalid states with feedback messages.'           },
  { label: 'Navs & Tabs',   href: '/components/bootstrap/navs',        desc: 'Tab navigation with switchable content panels.'             },
  { label: 'Navbar',        href: '/components/bootstrap/navbar',       desc: 'Expandable navigation bar with branding.'                   },
  { label: 'Breadcrumb',    href: '/components/bootstrap/breadcrumb',   desc: 'Hierarchical page location indicator.'                      },
  { label: 'Pagination',    href: '/components/bootstrap/pagination',   desc: 'Previous/next and numbered page navigation.'               },
  { label: 'Dropdowns',     href: '/components/bootstrap/dropdowns',    desc: 'Toggle menus with button triggers.'                        },
  { label: 'Accordion',     href: '/components/bootstrap/accordion',    desc: 'Collapsible sections with animated height.'                 },
  { label: 'Modal',         href: '/components/bootstrap/modal',        desc: 'Dialog overlays with header, body, and footer.'            },
  { label: 'Offcanvas',     href: '/components/bootstrap/offcanvas',    desc: 'Slide-out panel from any edge of the screen.'              },
  { label: 'Progress',      href: '/components/bootstrap/progress',     desc: 'Animated progress bars with color variants.'               },
  { label: 'Spinners',      href: '/components/bootstrap/spinners',     desc: 'Loading indicators in border and grow styles.'             },
  { label: 'Toasts',        href: '/components/bootstrap/toasts',       desc: 'Lightweight notification messages with auto-dismiss.'      },
  { label: 'Carousel',      href: '/components/bootstrap/carousel',     desc: 'Image slideshow with controls and indicators.'             },
  { label: 'Tooltips',      href: '/components/bootstrap/tooltips',     desc: 'Hover-activated contextual hints.'                         },
  { label: 'Popovers',      href: '/components/bootstrap/popovers',     desc: 'Click-triggered overlays with title and content.'         },
  { label: 'Placeholders',  href: '/components/bootstrap/placeholders', desc: 'Skeleton loading states with glow and wave animations.'    },
];

const otherComponents = [
  { label: 'Table 2.2.1',     href: '/components/table',           desc: 'jQuery data table with AJAX, sorting, and animations.'   },
  { label: 'Selectize',       href: '/components/selectize',       desc: 'Hybrid text input and select box.'                       },
  { label: 'Summernote',      href: '/components/summernote',      desc: 'WYSIWYG rich text editor.'                               },
  { label: 'Repeater',        href: '/components/repeater',        desc: 'Dynamic repeatable form field groups.'                   },
  { label: 'Noty',            href: '/components/noty',            desc: 'Notification and alert library.'                         },
  { label: 'Mask',            href: '/components/mask',            desc: 'Input mask for formatted values.'                        },
  { label: 'Highcharts',      href: '/components/highcharts',      desc: 'Interactive charting library.'                           },
  { label: 'Wizard Form',     href: '/components/wizard-form',     desc: 'Multi-step form wizard with progress.'                   },
  { label: 'Treeview',        href: '/components/treeview',        desc: 'Hierarchical tree navigation component.'                 },
  { label: 'Template Editor', href: '/components/template-editor', desc: 'Visual template editing interface.'                      },
  { label: 'Moment',          href: '/components/moment',          desc: 'Date and time formatting utilities.'                     },
  { label: 'File Viewer',     href: '/components/file-viewer',     desc: 'In-browser document and image preview.'                  },
  { label: 'Form Validation', href: '/components/form-validation', desc: 'Client-side form validation rules and feedback.'         },
  { label: 'File Upload',     href: '/components/file-upload',     desc: 'Drag-and-drop and multi-file upload.'                    },
  { label: 'Dropzone',        href: '/components/dropzone',        desc: 'Visual drop target for file uploads.'                    },
  { label: 'Numeral',         href: '/components/numeral',         desc: 'Number formatting and localization.'                     },
];
---

<BaseLayout title="Components" activeSection="components">
  <PageHeader
    eyebrow="Components"
    title="Component Library"
    description="Bootstrap 5.3 components themed for Voyadores, plus additional third-party integrations. Each component has a dedicated page with live demos and code reference."
  />

  <!-- Bootstrap section -->
  <section class="csec">
    <div class="csec-header">
      <h2>Bootstrap 5.3</h2>
      <span class="csec-count">{bootstrapComponents.length}</span>
    </div>
    <p class="csec-desc">All Bootstrap 5.3.1 components restyled with the Voyadores theme. Click any card to see the live demo and code reference.</p>
    <div class="comp-grid">
      {bootstrapComponents.map(c => (
        <a href={c.href} class="comp-card">
          <span class="comp-card-label">{c.label}</span>
          <span class="comp-card-desc">{c.desc}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Others section -->
  <section class="csec">
    <div class="csec-header">
      <h2>Others</h2>
      <span class="csec-count">{otherComponents.length}</span>
    </div>
    <p class="csec-desc">Third-party and custom components integrated with the Voyadores design system.</p>
    <div class="comp-grid">
      {otherComponents.map(c => (
        <a href={c.href} class="comp-card">
          <span class="comp-card-label">{c.label}</span>
          <span class="comp-card-desc">{c.desc}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .csec { margin-bottom: 64px; }

  .csec-header {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 16px; border-bottom: 1px solid var(--g5);
    margin-bottom: 12px;
  }
  .csec-header h2 {
    font-size: 20px; font-weight: 500; letter-spacing: -.4px;
    color: var(--black); margin: 0;
  }
  .csec-count {
    display: inline-flex; align-items: center; justify-content: center;
    height: 20px; padding: 0 7px; border-radius: 10px;
    background: var(--g5); color: var(--g2);
    font-size: 11px; font-weight: 600;
  }

  .csec-desc {
    font-size: 13px; color: var(--g2); line-height: 1.7;
    margin-bottom: 20px;
  }

  /* Component grid */
  .comp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .comp-card {
    display: flex; flex-direction: column; gap: 4px;
    padding: 16px 18px;
    border: 1px solid var(--g5); border-radius: 6px;
    background: var(--white); text-decoration: none;
    transition: border-color .15s, box-shadow .15s, transform .15s;
  }
  .comp-card:hover {
    border-color: var(--brand);
    box-shadow: 0 2px 12px rgba(247,146,30,.12);
    transform: translateY(-1px);
  }

  .comp-card-label {
    font-size: 13px; font-weight: 600; color: var(--black);
    line-height: 1.3;
  }
  .comp-card-desc {
    font-size: 11px; color: var(--g3); line-height: 1.5;
  }
</style>
