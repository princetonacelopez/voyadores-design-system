const groups = ['Foundation', 'Voyadores Components', 'Third-party', 'Utilities'];

const totalFiles = categories.reduce((n, c) => n + c.files.length, 0);
---

<BaseLayout title="CDN Files" activeSection="resources">
  <PageHeader
    eyebrow="Get Started — Develop"
    title="CDN Files"
    description={`${totalFiles} files across ${categories.length} libraries, served from the Voyadores CDN. Copy any URL to reference it directly in your project.`}
  />

  <!-- CDN banner -->
  <section class="sec">
    <div class="cdn-banner">
      <div class="cdn-banner-left">
        <span class="cdn-label">Base URL</span>
        <code class="cdn-url">https://cdn.voyadores.com/content</code>
      </div>
      <button class="copy-base-btn" data-copy="https://cdn.voyadores.com/content">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        Copy
      </button>
    </div>
    <p class="cdn-note">All files follow the pattern: <code>https://cdn.voyadores.com/content/<em>path/to/file.ext</em></code></p>
  </section>

  <!-- Filter bar -->
  <section class="sec">
    <div class="filter-bar">
      <div class="search-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchInput" placeholder="Filter by filename or path…" autocomplete="off" />
      </div>
      <div class="type-tabs">
        <button class="tt tt--active" data-type="all">All</button>
        <button class="tt tt--css" data-type="css">CSS</button>
        <button class="tt tt--js" data-type="js">JS</button>
      </div>
    </div>
  </section>

  <!-- File groups -->
  {groups.map(group => {
    const groupCats = categories.filter(c => c.group === group);
    return (
      <section class="sec group-sec" data-group={group}>
        <h2 class="group-heading">{group}</h2>
        <div class="cat-list">
          {groupCats.map(cat => (
            <div class="cat-block" data-cat={cat.name}>
              <div class="cat-header">
                <div class="cat-icon" style={`color:${cat.color};background:${cat.bg}`}>
                  <i class:list={['vi-regular', cat.icon]}></i>
                </div>
                <div class="cat-meta">
                  <h3>{cat.name}</h3>
                  <p>{cat.desc}</p>
                </div>
                <span class="cat-count">{cat.files.length}</span>
              </div>
              <div class="file-list">
                {cat.files.map(file => (
                  <div class="file-row" data-type={file.type} data-path={file.path}>
                    <span class:list={['type-badge', `type-${file.type}`]}>{file.type}</span>
                    <span class="file-name">{file.path.split('/').pop()}</span>
                    <span class="file-dir">/{file.path.split('/').slice(0, -1).join('/')}/</span>
                    <button class="copy-url-btn" data-copy={`${CDN}/${file.path}`}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                      Copy URL
                    </button>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}

  <p class="no-results" id="noResults" style="display:none">No files match your filter.</p>
</BaseLayout>

<script is:inline>
  // ── Copy to clipboard ────────────────────────────────────────────────────
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-copy]');
    if (!btn) return;
    var url = btn.dataset.copy;
    navigator.clipboard.writeText(url).then(function () {
      var original = btn.innerHTML;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(function () {
        btn.innerHTML = original;
        btn.classList.remove('copied');
      }, 1500);
    });
  });

  // ── Filter ───────────────────────────────────────────────────────────────
  var searchInput = document.getElementById('searchInput');
  var typeBtns = document.querySelectorAll('.tt');
  var noResults = document.getElementById('noResults');
  var activeType = 'all';

  function applyFilter() {
    var q = searchInput.value.toLowerCase().trim();

    document.querySelectorAll('.file-row').forEach(function (row) {
      var path = row.dataset.path.toLowerCase();
      var type = row.dataset.type;
      var typeMatch = activeType === 'all' || type === activeType;
      var searchMatch = !q || path.includes(q);
      row.style.display = (typeMatch && searchMatch) ? '' : 'none';
    });

    // Hide empty cat-blocks
    var anyVisible = false;
    document.querySelectorAll('.cat-block').forEach(function (block) {
      var vis = Array.from(block.querySelectorAll('.file-row')).some(function (r) {
        return r.style.display !== 'none';
      });
      block.style.display = vis ? '' : 'none';
      if (vis) anyVisible = true;
    });

    // Hide empty group-secs
    document.querySelectorAll('.group-sec').forEach(function (sec) {
      var vis = Array.from(sec.querySelectorAll('.cat-block')).some(function (b) {
        return b.style.display !== 'none';
      });
      sec.style.display = vis ? '' : 'none';
    });

    noResults.style.display = anyVisible ? 'none' : 'block';
  }

  typeBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      typeBtns.forEach(function (b) { b.classList.remove('tt--active'); });
      btn.classList.add('tt--active');
      activeType = btn.dataset.type;
      applyFilter();
    });
  });

  searchInput.addEventListener('input', applyFilter);
</script>

<style>
  .sec { margin-bottom: 56px; }

  /* CDN Banner */
  .cdn-banner {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 16px 20px; border: 1px solid var(--g5); border-radius: 4px;
    background: var(--g6);
  }
  .cdn-banner-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
  .cdn-label {
    font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--g2); white-space: nowrap;
  }
  .cdn-url {
    font-family: var(--mono); font-size: 13px; color: var(--black);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .copy-base-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font); font-size: 12px; font-weight: 600;
    padding: 7px 14px; border-radius: 4px; border: 1px solid var(--g4);
    background: var(--white); color: var(--black); cursor: pointer;
    white-space: nowrap; transition: border-color .12s, background .12s;
  }
  .copy-base-btn:hover { border-color: var(--g3); background: var(--g6); }
  .copy-base-btn.copied { color: #077d55; border-color: #077d55; }

  .cdn-note {
    margin-top: 10px; font-size: 12px; color: var(--g2); line-height: 1.6;
  }
  .cdn-note code { font-family: var(--mono); font-size: 12px; color: var(--g1); }
  .cdn-note em { font-style: normal; color: var(--brand); }

  /* Filter bar */
  .filter-bar {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  }
  .search-wrap {
    position: relative; flex: 1; min-width: 200px;
  }
  .search-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    color: var(--g3); pointer-events: none;
  }
  #searchInput {
    width: 100%; padding: 9px 12px 9px 36px;
    font-family: var(--font); font-size: 13px; color: var(--black);
    border: 1px solid var(--g5); border-radius: 4px;
    background: var(--white); outline: none; transition: border-color .12s;
  }
  #searchInput:focus { border-color: var(--brand); }
  #searchInput::placeholder { color: var(--g3); }

  .type-tabs { display: flex; gap: 4px; }
  .tt {
    padding: 7px 16px; border-radius: 4px; border: 1px solid var(--g5);
    font-family: var(--font); font-size: 12px; font-weight: 600;
    color: var(--g2); background: var(--white); cursor: pointer;
    transition: border-color .12s, color .12s, background .12s;
  }
  .tt:hover { border-color: var(--g3); color: var(--black); }
  .tt--active { border-color: var(--black); color: var(--black); background: var(--g6); }
  .tt--css.tt--active { border-color: #186ade; color: #186ade; background: rgba(24,106,222,.06); }
  .tt--js.tt--active  { border-color: #f5c518; color: #70491c; background: rgba(245,197,24,.1); }

  /* Group headings */
  .group-heading {
    font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--g2); margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--g5);
  }

  /* Category blocks */
  .cat-list { display: flex; flex-direction: column; gap: 8px; }

  .cat-block { border: 1px solid var(--g5); border-radius: 4px; overflow: hidden; }

  .cat-header {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px; background: var(--white);
  }
  .cat-icon {
    width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
  }
  .cat-meta { flex: 1; min-width: 0; }
  .cat-meta h3 { font-size: 13px; font-weight: 600; color: var(--black); margin-bottom: 2px; }
  .cat-meta p  { font-size: 12px; color: var(--g2); line-height: 1.4; }
  .cat-count {
    font-size: 10px; font-weight: 700; font-family: var(--mono);
    color: var(--g2); background: var(--g6); border: 1px solid var(--g5);
    padding: 3px 8px; border-radius: 100px; white-space: nowrap;
  }

  /* File list */
  .file-list { border-top: 1px solid var(--g5); }

  .file-row {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 16px; border-bottom: 1px solid var(--g6);
    transition: background .08s;
  }
  .file-row:last-child { border-bottom: none; }
  .file-row:hover { background: rgba(0,0,0,.015); }

  .type-badge {
    font-family: var(--mono); font-size: 9px; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase;
    padding: 2px 6px; border-radius: 3px; flex-shrink: 0;
  }
  .type-css { background: rgba(24,106,222,.1); color: #186ade; }
  .type-js  { background: rgba(245,197,24,.15); color: #70491c; }

  .file-name {
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    color: var(--black); white-space: nowrap; flex-shrink: 0;
  }
  .file-dir {
    font-family: var(--mono); font-size: 11px; color: var(--g3);
    flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  .copy-url-btn {
    display: inline-flex; align-items: center; gap: 5px; flex-shrink: 0;
    font-family: var(--font); font-size: 11px; font-weight: 600; color: var(--g2);
    padding: 5px 10px; border-radius: 3px; border: 1px solid var(--g5);
    background: var(--white); cursor: pointer;
    transition: border-color .1s, color .1s, background .1s; white-space: nowrap;
  }
  .copy-url-btn:hover { border-color: var(--g3); color: var(--black); background: var(--g6); }
  .copy-url-btn.copied { color: #077d55; border-color: #077d55; background: rgba(7,125,85,.05); }

  /* No results */
  .no-results {
    text-align: center; font-size: 13px; color: var(--g2); padding: 48px 0;
  }

  @media (max-width: 640px) {
    .file-dir { display: none; }
    .cdn-banner { flex-direction: column; align-items: flex-start; }
    .filter-bar { flex-direction: column; align-items: stretch; }
    .type-tabs { width: 100%; }
    .tt { flex: 1; text-align: center; }
  }
</style>
