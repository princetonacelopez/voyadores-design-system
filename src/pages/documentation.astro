---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const appShell = [
  { label: 'Browser & TZ Detection', href: '/docs/detection',    desc: 'Detects browser type, version, and timezone for application configuration.' },
  { label: 'Menu Web',               href: '/docs/menu-web',     desc: 'Dynamic web navigation menu management and rendering.'                       },
  { label: 'Theme Picker',           href: '/docs/theme-picker', desc: 'Application theme selection and persistence.'                                },
];

const modules = [
  { label: 'Default URL',        href: '/docs/default-url',         desc: 'Manages the default landing URL per user role and context.'          },
  { label: 'Feature Onboarding', href: '/docs/feature-onboarding',  desc: 'Guided feature spotlight tours with step-by-step overlays.'          },
  { label: 'Notifications',      href: '/docs/notifications',       desc: 'In-app notification system with polling, badge, and read states.'    },
  { label: 'Quick Links',        href: '/docs/quicklinks',          desc: 'User-customizable shortcut link panel for quick navigation.'         },
  { label: 'User Onboarding',    href: '/docs/user-onboarding',     desc: 'First-run onboarding flow for new user account setup.'               },
  { label: 'Visual Indicator',   href: '/docs/visual-indicator',    desc: 'Status and progress indicators shown in the application shell.'       },
];

const utilities = [
  { label: 'Browser Storage',  href: '/docs/browser-storage',  desc: 'Unified API for localStorage, sessionStorage, and cookie access.'    },
  { label: 'DateTime Picker',  href: '/docs/datetime-picker',  desc: 'jQuery-based date and time picker with Voyadores theme integration.'  },
  { label: 'Request & URI',    href: '/docs/request-and-uri',  desc: 'HTTP request helpers and URI parsing and construction utilities.'     },
  { label: 'ViewModelBase',    href: '/docs/view-model',       desc: 'Base ViewModel class providing observable state and lifecycle hooks.' },
];

const plugins = [
  { label: 'Action Button Manager', href: '/docs/action-button-manager', desc: 'State-aware toolbar button manager with permission control.'          },
  { label: 'Currency Picker',       href: '/docs/currency-picker',       desc: 'Searchable currency selection dropdown with formatting.'              },
  { label: 'File Template Editor',  href: '/docs/file-template-editor',  desc: 'WYSIWYG and code editor for HTML and CSHTML file templates.'          },
  { label: 'Repeater',              href: '/docs/repeater',              desc: 'Dynamic add/remove row repeater for form field groups.'               },
  { label: 'Table Plugin',          href: '/docs/table-plugin',          desc: 'Data table with AJAX loading, sorting, filtering, and pagination.'    },
  { label: 'Template Editor',       href: '/docs/template-editor',       desc: 'Multi-section evaluation form builder, viewer, and dual-role review.' },
  { label: 'Treeview',              href: '/docs/treeview',              desc: 'Hierarchical tree navigation with expand/collapse support.'            },
  { label: 'Wizard Form',           href: '/docs/wizard-form',           desc: 'Multi-step modal form wizard with progress bar and callbacks.'        },
];

const sections = [
  { title: 'App Shell',  desc: 'Core shell-level features that handle browser configuration, navigation, and theming.', items: appShell  },
  { title: 'Modules',    desc: 'Application modules that extend the Voyadores shell with specific user-facing features.', items: modules   },
  { title: 'Utilities',  desc: 'Low-level helpers for storage, HTTP, URI parsing, and ViewModel architecture.', items: utilities },
  { title: 'Plugins',    desc: 'Specialized components and editors integrated into the Voyadores application framework.', items: plugins   },
];

const total = [...appShell, ...modules, ...utilities, ...plugins].length;
---

<BaseLayout title="Documentation">
  <PageHeader
    eyebrow="Documentation"
    title="Documentation"
    description={`${total} technical reference documents covering Voyadores application modules, utilities, and plugins.`}
  />

  {sections.map(sec => (
    <section class="csec">
      <div class="csec-header">
        <h2>{sec.title}</h2>
        <span class="csec-count">{sec.items.length}</span>
      </div>
      <p class="csec-desc">{sec.desc}</p>
      <div class="comp-grid">
        {sec.items.map(c => (
          <a href={c.href} class="comp-card">
            <span class="comp-card-label">{c.label}</span>
            <span class="comp-card-desc">{c.desc}</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .csec { margin-bottom: 64px; }

  .csec-header {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 16px; border-bottom: 1px solid var(--g5);
    margin-bottom: 12px;
  }
  .csec-header h2 {
    font-size: 20px; font-weight: 500; letter-spacing: -.4px;
    color: var(--black); margin: 0;
  }
  .csec-count {
    display: inline-flex; align-items: center; justify-content: center;
    height: 20px; padding: 0 7px; border-radius: 10px;
    background: var(--g5); color: var(--g2);
    font-size: 11px; font-weight: 600;
  }

  .csec-desc {
    font-size: 13px; color: var(--g2); line-height: 1.7;
    margin-bottom: 20px; max-width: 640px;
  }

  .comp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .comp-card {
    display: flex; flex-direction: column; gap: 4px;
    padding: 16px 18px;
    border: 1px solid var(--g5); border-radius: 6px;
    background: var(--white); text-decoration: none;
    transition: border-color .15s, box-shadow .15s, transform .15s;
  }
  .comp-card:hover {
    border-color: var(--brand);
    box-shadow: 0 2px 12px rgba(247,146,30,.12);
    transform: translateY(-1px);
  }

  .comp-card-label {
    font-size: 13px; font-weight: 600; color: var(--black);
    line-height: 1.3;
  }
  .comp-card-desc {
    font-size: 11px; color: var(--g3); line-height: 1.5;
  }
</style>
