---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';

const figmaFiles = [
  {
    name: 'Voyadores Design System',
    description: 'Core UI components, design tokens, color styles, and typography — the single Figma source of truth for all Voyadores products.',
    url: '#',
    type: 'Design System',
  },
  {
    name: 'Voyadores Social Media',
    description: 'Templates and assets for social media posts, banners, and branded content across all Voyadores platforms.',
    url: '#',
    type: 'Marketing',
  },
];
---

<BaseLayout title="Figma Files">
  <PageHeader
    eyebrow="Get Started — Design"
    title="Figma Files"
    description="Access the official Voyadores Figma files. You'll need a Figma account and the appropriate team permissions to view and edit."
  />

  <div class="content">

    <section class="sec">
      <div class="file-grid">
        {figmaFiles.map(file => (
          <a class="file-card" href={file.url} target="_blank" rel="noopener noreferrer">
            <div class="file-card-icon">
              <svg width="28" height="28" viewBox="0 0 38 57" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 28.5C19 25.9804 20.0009 23.5641 21.7825 21.7825C23.5641 20.0009 25.9804 19 28.5 19C31.0196 19 33.4359 20.0009 35.2175 21.7825C36.9991 23.5641 38 25.9804 38 28.5C38 31.0196 36.9991 33.4359 35.2175 35.2175C33.4359 36.9991 31.0196 38 28.5 38C25.9804 38 23.5641 36.9991 21.7825 35.2175C20.0009 33.4359 19 31.0196 19 28.5Z" fill="#1ABCFE"/>
                <path d="M0 47.5C0 44.9804 1.00089 42.5641 2.78249 40.7825C4.56408 39.0009 6.98044 38 9.5 38H19V47.5C19 50.0196 17.9991 52.4359 16.2175 54.2175C14.4359 55.9991 12.0196 57 9.5 57C6.98044 57 4.56408 55.9991 2.78249 54.2175C1.00089 52.4359 0 50.0196 0 47.5Z" fill="#0ACF83"/>
                <path d="M19 0V19H28.5C31.0196 19 33.4359 17.9991 35.2175 16.2175C36.9991 14.4359 38 12.0196 38 9.5C38 6.98044 36.9991 4.56408 35.2175 2.78249C33.4359 1.00089 31.0196 0 28.5 0H19Z" fill="#FF7262"/>
                <path d="M0 9.5C0 12.0196 1.00089 14.4359 2.78249 16.2175C4.56408 17.9991 6.98044 19 9.5 19H19V0H9.5C6.98044 0 4.56408 1.00089 2.78249 2.78249C1.00089 4.56408 0 6.98044 0 9.5Z" fill="#F24E1E"/>
                <path d="M0 28.5C0 31.0196 1.00089 33.4359 2.78249 35.2175C4.56408 36.9991 6.98044 38 9.5 38H19V19H9.5C6.98044 19 4.56408 20.0009 2.78249 21.7825C1.00089 23.5641 0 25.9804 0 28.5Z" fill="#A259FF"/>
              </svg>
            </div>
            <div class="file-card-body">
              <div class="file-card-type">{file.type}</div>
              <h3 class="file-card-name">{file.name}</h3>
              <p class="file-card-desc">{file.description}</p>
            </div>
            <div class="file-card-action">
              <span class="file-card-open">Open in Figma</span>
              <svg class="file-card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="sec">
      <h2>Access & Permissions</h2>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div>
            <h4>Figma Account Required</h4>
            <p>You must have a Figma account to view these files. <a href="https://figma.com" target="_blank" rel="noopener">Sign up at figma.com</a> if you don't have one.</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div>
            <h4>Team Permissions</h4>
            <p>Editing rights are limited to the design team. Request access from your team lead or the design system owner.</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <h4>Always Use the Latest Version</h4>
            <p>Do not duplicate files into your personal drafts for production work. Always reference the shared team files to stay in sync.</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .content { padding: 0 0 96px; max-width: 860px; }

  .sec { margin-bottom: 64px; }
  .sec h2 {
    font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black);
    margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5);
  }

  /* ── Figma file cards ────────────────────────────────────────────────── */
  .file-grid {
    display: flex; flex-direction: column; gap: 12px;
  }

  .file-card {
    display: flex; align-items: center; gap: 20px;
    padding: 20px 24px;
    border: 1px solid var(--g5); border-radius: 8px;
    background: var(--white);
    text-decoration: none; color: inherit;
    transition: border-color .15s, box-shadow .15s;
  }
  .file-card:hover {
    border-color: var(--g3);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  .file-card-icon {
    flex-shrink: 0;
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    background: var(--g6); border-radius: 8px;
    border: 1px solid var(--g5);
  }

  .file-card-body { flex: 1; min-width: 0; }

  .file-card-type {
    font-size: 10px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--g3);
    margin-bottom: 4px;
  }

  .file-card-name {
    font-size: 15px; font-weight: 700; color: var(--black);
    margin: 0 0 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .file-card-desc {
    font-size: 12px; color: var(--g2); line-height: 1.5; margin: 0;
  }

  .file-card-action {
    flex-shrink: 0;
    display: flex; align-items: center; gap: 5px;
    font-size: 12px; font-weight: 600; color: var(--g2);
    transition: color .12s;
  }
  .file-card:hover .file-card-action { color: var(--black); }

  .file-card-arrow { transition: transform .15s; }
  .file-card:hover .file-card-arrow { transform: translate(2px, -2px); }

  /* ── Access info cards ───────────────────────────────────────────────── */
  .info-grid {
    display: flex; flex-direction: column; gap: 12px;
  }

  .info-card {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 16px 18px;
    border: 1px solid var(--g5); border-radius: 6px;
    background: var(--white);
  }

  .info-icon {
    flex-shrink: 0;
    width: 34px; height: 34px;
    display: flex; align-items: center; justify-content: center;
    background: var(--g6); border-radius: 6px;
    color: var(--g2);
  }

  .info-card h4 {
    font-size: 13px; font-weight: 700; color: var(--black);
    margin: 0 0 3px;
  }

  .info-card p {
    font-size: 12px; color: var(--g2); line-height: 1.6; margin: 0;
  }

  .info-card a {
    color: var(--brand); text-decoration: none;
  }
  .info-card a:hover { text-decoration: underline; }
</style>
