---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Introduction" activeSection="introduction">
  <PageHeader
    eyebrow="Introduction"
    title="Meet Voyadores"
    description="Voyadores builds enterprise web applications for Philippine MSMEs. This design system is the single source of truth for every visual, content, and interactive decision across our products."
  />

  <div class="content">

    <section class="sec">
      <h2>What is this?</h2>
      <p>
        The Voyadores Design System is a collection of reusable components, content guidelines,
        and design tokens that help teams build consistent, accessible, and high-quality user
        interfaces faster. For internal use by designers, developers, and system analysts—it removes
        guesswork and ensures every product we ship feels cohesively Voyadores.
      </p>
    </section>

    <section class="sec">
      <h2>Who is it for?</h2>
      <div class="audience-grid">
        <div class="audience-card">
          <div class="aud-icon"><i class="vi-regular vi-brush"></i></div>
          <h3>Designers</h3>
          <p>Figma libraries, color tokens, spacing guidelines, and visual patterns to design with confidence.</p>
        </div>
        <div class="audience-card">
          <div class="aud-icon"><i class="vi-regular vi-code"></i></div>
          <h3>Developers</h3>
          <p>Bootstrap 5 theme, CSS custom properties, JavaScript components, and integration guides.</p>
        </div>
        <div class="audience-card">
          <div class="aud-icon"><i class="vi-regular vi-chart-bar"></i></div>
          <h3>System Analysts</h3>
          <p>A shared language for specifying UI behavior, writing requirements, and validating that what ships matches intent.</p>
        </div>
        <div class="audience-card">
          <div class="aud-icon"><i class="vi-regular vi-briefcase"></i></div>
          <h3>Sales</h3>
          <p>Brand assets, visual standards, and presentation guidelines for client-facing communications and sales collateral.</p>
        </div>
      </div>
    </section>

    <section class="sec">
      <h2>What's inside</h2>
      <div class="contents-list">
        {[
          ['Strategy',        'Brand attributes, voice, and values that guide every design decision.'],
          ['Logo',            'Brand mark, wordmark, usage guidelines, clear space, and do\'s and don\'ts.'],
          ['Typography',      'Lexend (primary), Urbanist (alternative), and Chivo Mono — type scale, weights, and tokens.'],
          ['Color',           'Full palette — Luminous Orange, grays, semantic, and extended colors with CSS tokens.'],
          ['Images',          'Logos, illustrations, module backgrounds, and image usage guidelines.'],
          ['Icons',           '1,300+ icons via Voyadores-Icon font in regular and solid weights.'],
          ['Illustrations',   'SVG illustration library including empty states, alert states, and onboarding sets.'],
          ['Content',         'Writing standards, grammar rules, tone of voice, and microcopy patterns.'],
          ['Components',      'Bootstrap 5 components and Voyadores UI patterns with live demos and code.'],
          ['Documentation',   'Technical reference docs for application modules, utilities, and plugins.'],
          ['Figma Libraries', 'Shared Figma design files for the design system, social media, and helpsite.'],
        ].map(([title, desc]) => (
          <div class="contents-row">
            <span class="cr-title">{title}</span>
            <span class="cr-sep">—</span>
            <span class="cr-desc">{desc}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="sec">
      <h2>Version</h2>
      <div class="version-badge">v1.1.0 — March 2026</div>
    </section>

  </div>
</BaseLayout>

<style>
  .content { display: flex; flex-direction: column; }

  .sec {
    margin-bottom: 64px;
  }

  .sec h2 {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.4px;
    color: var(--black);
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--g5);
  }

  .sec > p {
    font-size: 16px;
    font-weight: 500;
    color: var(--g2);
    line-height: 1.7;
    max-width: 600px;
  }

  /* Audience */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }

  .audience-card {
    padding: 24px;
    border: 1px solid var(--g5);
    border-radius: 2px;
  }

  .aud-icon {
    font-size: 1.5rem;
    color: var(--black);
    margin-bottom: 14px;
    line-height: 1;
  }

  .audience-card h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 8px;
  }

  .audience-card p {
    font-size: 13px;
    font-weight: 500;
    color: var(--g2);
    line-height: 1.6;
  }

  /* Contents list */
  .contents-list {
    display: flex;
    flex-direction: column;
  }

  .contents-row {
    display: grid;
    grid-template-columns: 120px 16px 1fr;
    align-items: baseline;
    gap: 0 8px;
    padding: 14px 0;
    border-bottom: 1px solid var(--g5);
    font-size: 14px;
  }
  .contents-row:first-child { border-top: 1px solid var(--g5); }

  .cr-title { font-weight: 600; color: var(--black); }
  .cr-sep   { color: var(--g3); }
  .cr-desc  { font-weight: 500; color: var(--g2); line-height: 1.5; }

  /* Version badge */
  .version-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--mono);
    color: var(--g1);
    background: var(--g6);
    border: 1px solid var(--g5);
    border-radius: 100px;
    padding: 6px 16px;
  }

  @media (max-width: 900px) {
    .audience-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .audience-grid { grid-template-columns: repeat(2, 1fr); }
    .contents-row  { grid-template-columns: 1fr; }
    .cr-sep { display: none; }
  }
  @media (max-width: 480px) {
    .audience-grid { grid-template-columns: 1fr; }
  }
</style>
