---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="Highcharts" activeSection="components">

  <PageHeader
    eyebrow="Components / Others"
    title="Highcharts"
    description="Interactive SVG-based charting library for line, bar, pie, area, and more. Use the Voyadores ERP theme for brand-aligned chart colors."
  />

  <section class="sec">
    <h2>Setup</h2>
    <div class="code-block"><pre is:raw><code>&lt;script src="https://cdn.voyadores.com/content/js/highcharts/highcharts.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.voyadores.com/content/js/highcharts/highcharts-more.min.js"&gt;&lt;/script&gt;
&lt;!-- Optional: Voyadores brand theme --&gt;
&lt;script src="https://cdn.voyadores.com/content/js/highcharts/themes/erp-theme.min.js"&gt;&lt;/script&gt;</code></pre></div>
  </section>

  <section class="sec">
    <h2>Demo</h2>
    <div class="chart-grid">
      <div class="chart-card">
        <p class="chart-label">Monthly Revenue (Bar)</p>
        <div id="chart-bar" class="chart-box"></div>
      </div>
      <div class="chart-card">
        <p class="chart-label">Sales Trend (Line)</p>
        <div id="chart-line" class="chart-box"></div>
      </div>
      <div class="chart-card">
        <p class="chart-label">Expense Breakdown (Pie)</p>
        <div id="chart-pie" class="chart-box"></div>
      </div>
      <div class="chart-card">
        <p class="chart-label">Performance (Area)</p>
        <div id="chart-area" class="chart-box"></div>
      </div>
    </div>
  </section>

  <section class="sec">
    <h2>Usage</h2>
    <div class="code-block"><pre is:raw><code>// Bar chart
Highcharts.chart('container', {
  chart: { type: 'bar' },
  title: { text: 'Revenue by Month' },
  xAxis: { categories: ['Jan', 'Feb', 'Mar'] },
  yAxis: { title: { text: 'Amount (₱)' } },
  series: [{ name: 'Revenue', data: [420000, 380000, 510000] }],
});

// Pie chart
Highcharts.chart('container', {
  chart: { type: 'pie' },
  title: { text: 'Expense Breakdown' },
  series: [{
    name: 'Amount',
    data: [
      { name: 'Salaries', y: 45 },
      { name: 'Operations', y: 30 },
      { name: 'Marketing', y: 25 },
    ],
  }],
});</code></pre></div>
  </section>
</BaseLayout>

<script is:inline src="/js/highcharts/highcharts.min.js"></script>
<script is:inline>
(function () {
  var brand   = '#f7921e';
  var palette = ['#f7921e','#186ade','#077d55','#d91f11','#545fe8','#cc1d92','#167b7d','#f5c518'];
  var months  = ['Jan','Feb','Mar','Apr','May','Jun'];
  var common  = { credits: { enabled: false }, legend: { enabled: false } };

  Highcharts.chart('chart-bar', Object.assign({}, common, {
    chart: { type: 'column', height: 220, backgroundColor: 'transparent' },
    title: { text: null },
    xAxis: { categories: months, lineColor: '#e5e5e5', tickColor: '#e5e5e5', labels: { style: { fontSize: '11px' } } },
    yAxis: { title: { text: null }, gridLineColor: '#f0f0f0', labels: { style: { fontSize: '11px' } } },
    colors: [brand],
    series: [{ name: 'Revenue', data: [420, 380, 510, 470, 595, 630] }],
    plotOptions: { column: { borderRadius: 3, borderWidth: 0 } },
  }));

  Highcharts.chart('chart-line', Object.assign({}, common, {
    chart: { type: 'line', height: 220, backgroundColor: 'transparent' },
    title: { text: null },
    xAxis: { categories: months, lineColor: '#e5e5e5', tickColor: '#e5e5e5', labels: { style: { fontSize: '11px' } } },
    yAxis: { title: { text: null }, gridLineColor: '#f0f0f0', labels: { style: { fontSize: '11px' } } },
    colors: ['#186ade'],
    series: [{ name: 'Sales', data: [210, 250, 230, 310, 290, 370], marker: { radius: 4 } }],
    plotOptions: { line: { lineWidth: 2 } },
  }));

  Highcharts.chart('chart-pie', Object.assign({}, common, {
    chart: { type: 'pie', height: 220, backgroundColor: 'transparent' },
    title: { text: null },
    colors: palette,
    legend: { enabled: true, itemStyle: { fontSize: '11px', fontWeight: '500' } },
    series: [{ name: 'Amount', data: [
      { name: 'Salaries', y: 45 }, { name: 'Operations', y: 30 }, { name: 'Marketing', y: 25 }
    ], innerSize: '50%' }],
  }));

  Highcharts.chart('chart-area', Object.assign({}, common, {
    chart: { type: 'area', height: 220, backgroundColor: 'transparent' },
    title: { text: null },
    xAxis: { categories: months, lineColor: '#e5e5e5', tickColor: '#e5e5e5', labels: { style: { fontSize: '11px' } } },
    yAxis: { title: { text: null }, gridLineColor: '#f0f0f0', labels: { style: { fontSize: '11px' } } },
    colors: ['#077d55'],
    series: [{ name: 'Target', data: [80, 85, 78, 92, 88, 96], fillOpacity: 0.15 }],
    plotOptions: { area: { lineWidth: 2, marker: { radius: 3 } } },
  }));
})();
</script>

<style>
  .sec { margin-bottom: 56px; }
  .sec h2 { font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5); }
  .code-block { background: #161616; border-radius: 4px; overflow: auto; }
  .code-block pre { margin: 0; padding: 20px 24px; }
  .code-block code { font-family: var(--mono); font-size: 13px; color: #f5f5f5; line-height: 1.8; white-space: pre; }
  .chart-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .chart-card { border: 1px solid var(--g5); border-radius: 4px; padding: 16px; background: var(--white); }
  .chart-label { font-size: 11px; font-weight: 600; color: var(--g2); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 8px; }
  .chart-box { width: 100%; }
  @media (max-width: 640px) { .chart-grid { grid-template-columns: 1fr; } }
</style>
