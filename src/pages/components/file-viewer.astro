---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="File Viewer" activeSection="components">

  <PageHeader
    eyebrow="Components / Others"
    title="File Viewer"
    description="Modular ES6 file viewer factory supporting PDF, image (PNG/JPG/SVG), and CSV file types. Uses a factory pattern — each viewer handles rendering for its own file type."
  />

  <section class="sec">
    <h2>Setup</h2>
    <div class="code-block"><pre is:raw><code>&lt;!-- PDF.js (required for PDF viewing) --&gt;
&lt;script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"&gt;&lt;/script&gt;

&lt;script type="module"&gt;
import { FileViewerFactory } from 'https://cdn.voyadores.com/content/js/file-viewer/file-viewer-factory.min.js';
&lt;/script&gt;</code></pre></div>
  </section>

  <section class="sec">
    <h2>Demo</h2>
    <div class="demo-area">
      <input id="voyadores-cdn-url" type="hidden" value="" />
      <div class="fv-pick-area">
        <label class="fv-pick-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Choose File
          <input id="fv-file-input" type="file" accept=".pdf,.png,.jpg,.jpeg,.svg,.csv" />
        </label>
        <span id="fv-filename" class="fv-filename">No file selected</span>
      </div>
      <div id="file-viewer-container" class="fv-viewer-wrap">
        <div class="fv-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity=".25"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p>Select a PDF, image, or CSV file to preview</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <h2>Usage</h2>
    <div class="code-block"><pre is:raw><code>// Requires PDF.js loaded as a global script (for PDF support):
// &lt;script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"&gt;&lt;/script&gt;
// Also requires &lt;input id="voyadores-cdn-url" type="hidden" value="https://cdn.voyadores.com" /&gt;
// and &lt;div id="file-viewer-container"&gt;&lt;/div&gt; in the DOM.

import { FileViewerFactory } from 'https://cdn.voyadores.com/content/js/file-viewer/file-viewer-factory.min.js';

// Create a viewer for a file type
const viewer = FileViewerFactory.createViewer('.pdf');  // PDFViewer
// const viewer = FileViewerFactory.createViewer('.png');  // ImageViewer
// const viewer = FileViewerFactory.createViewer('.csv');  // CSVViewer

// Render into #file-viewer-container
await viewer.render(file);  // file = File object from input

// Supported types
// .pdf  → PDFViewer  (uses PDF.js)
// .png  → ImageViewer
// .jpg  → ImageViewer
// .jpeg → ImageViewer
// .svg  → ImageViewer
// .csv  → CSVViewer  (renders a sortable HTML table)</code></pre></div>
  </section>
</BaseLayout>

<script is:inline src="/js/pdfjs/pdf.min.js"></script>
<script is:inline type="module">
import { FileViewerFactory } from '/js/file-viewer/file-viewer-factory.min.js';

var input = document.getElementById('fv-file-input');
var filenameEl = document.getElementById('fv-filename');

input.addEventListener('change', async function () {
  var file = this.files[0];
  if (!file) return;

  filenameEl.textContent = file.name;

  var container = document.getElementById('file-viewer-container');
  container.innerHTML = '<div class="fv-loading">Loading\u2026</div>';

  try {
    var ext = '.' + file.name.split('.').pop().toLowerCase();
    var viewer = FileViewerFactory.createViewer(ext);
    await viewer.render(file);
  } catch (e) {
    document.getElementById('file-viewer-container').innerHTML =
      '<div class="fv-error">Unsupported file type or error: ' + e.message + '</div>';
  }
});
</script>

<style>
  .sec { margin-bottom: 56px; }
  .sec h2 { font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5); }
  .code-block { background: #161616; border-radius: 4px; overflow: auto; }
  .code-block pre { margin: 0; padding: 20px 24px; }
  .code-block code { font-family: var(--mono); font-size: 13px; color: #f5f5f5; line-height: 1.8; white-space: pre; }
  .demo-area { padding: 24px; border: 1px solid var(--g5); border-radius: 2px; background: var(--white); }

  /* Pick row */
  .fv-pick-area { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .fv-pick-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; background: var(--brand); color: #fff;
    font-size: 12px; font-weight: 600; border-radius: 4px; cursor: pointer;
    border: none; transition: opacity .15s;
  }
  .fv-pick-btn:hover { opacity: .88; }
  .fv-pick-btn input { display: none; }
  .fv-filename { font-size: 12px; color: var(--g2); font-family: var(--mono); }

  /* Viewer wrapper */
  .fv-viewer-wrap { border: 1px solid var(--g5); border-radius: 4px; min-height: 300px; overflow: auto; background: var(--g6); }
  .fv-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px; gap: 12px; color: var(--g3); }
  .fv-placeholder p { font-size: 13px; margin: 0; }
  .fv-loading { display: flex; align-items: center; justify-content: center; min-height: 300px; font-size: 13px; color: var(--g2); }
  .fv-error { display: flex; align-items: center; justify-content: center; min-height: 300px; font-size: 13px; color: #d91f11; padding: 24px; text-align: center; }
</style>
