---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Navs &amp; Tabs" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Navs &amp; Tabs"
    description="Use .nav with .nav-tabs or .nav-pills. Pair with .tab-content / .tab-pane and Bootstrap JS for switching behavior."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;gap:24px;align-items:stretch">
        <!-- Tabs -->
        <div>
          <ul class="nav nav-tabs" id="demoTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="tab-a-tab" data-bs-toggle="tab" data-bs-target="#tab-a" type="button" role="tab">Overview</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-b-tab" data-bs-toggle="tab" data-bs-target="#tab-b" type="button" role="tab">Details</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-c-tab" data-bs-toggle="tab" data-bs-target="#tab-c" type="button" role="tab">Settings</button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link disabled" type="button" disabled>Disabled</button>
            </li>
          </ul>
          <div class="tab-content border border-top-0 p-3">
            <div class="tab-pane fade show active" id="tab-a" role="tabpanel">Overview content — the main summary and key metrics.</div>
            <div class="tab-pane fade" id="tab-b" role="tabpanel">Details content — granular breakdown of each item.</div>
            <div class="tab-pane fade" id="tab-c" role="tabpanel">Settings content — configure preferences and options.</div>
          </div>
        </div>
        <!-- Pills -->
        <ul class="nav nav-pills gap-1">
          <li class="nav-item"><a class="nav-link active" href="#">Active</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          <li class="nav-item"><a class="nav-link disabled">Disabled</a></li>
        </ul>
        <!-- Underline nav -->
        <ul class="nav nav-underline">
          <li class="nav-item"><a class="nav-link active" href="#">Active</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
        </ul>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-navs">HTML</button>
        <button class="cb-tab" data-tab="js-navs">JS</button>
      </div>
      <pre is:raw id="html-navs"><code>&lt;!-- Tab navigation --&gt;
&lt;ul class="nav nav-tabs" id="myTabs" role="tablist"&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;button class="nav-link active" data-bs-toggle="tab" data-bs-target="#panel1" type="button" role="tab"&gt;
      Tab One
    &lt;/button&gt;
  &lt;/li&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;button class="nav-link" data-bs-toggle="tab" data-bs-target="#panel2" type="button" role="tab"&gt;
      Tab Two
    &lt;/button&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;div class="tab-content"&gt;
  &lt;div class="tab-pane fade show active" id="panel1" role="tabpanel"&gt;Content one&lt;/div&gt;
  &lt;div class="tab-pane fade" id="panel2" role="tabpanel"&gt;Content two&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Pills --&gt;
&lt;ul class="nav nav-pills"&gt;
  &lt;li class="nav-item"&gt;&lt;a class="nav-link active" href="#"&gt;Active&lt;/a&gt;&lt;/li&gt;
  &lt;li class="nav-item"&gt;&lt;a class="nav-link" href="#"&gt;Link&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;!-- Underline --&gt;
&lt;ul class="nav nav-underline"&gt;
  &lt;li class="nav-item"&gt;&lt;a class="nav-link active" href="#"&gt;Active&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;</code></pre>
      <pre is:raw id="js-navs" style="display:none"><code>// Programmatic tab activation
const tab = new bootstrap.Tab(document.querySelector('#myTab'));
tab.show();

// Tab events
document.getElementById('myTabs').addEventListener('shown.bs.tab', event =&gt; {
  console.log('Active tab:', event.target); // newly activated tab
  console.log('Previous tab:', event.relatedTarget);
});</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
