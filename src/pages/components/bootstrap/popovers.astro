---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Popovers" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Popovers"
    description="Like tooltips but richer — supports a header title plus body content. Must be manually initialized. Click-triggered by default."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:10px;align-items:center;flex-wrap:wrap">
        <button type="button" class="btn btn-primary"
          data-bs-toggle="popover"
          data-bs-title="Popover Title"
          data-bs-content="This is the popover body. Use it for contextual help or extra detail."
          data-bs-placement="top">
          Click me (Top)
        </button>
        <button type="button" class="btn btn-outline-secondary"
          data-bs-toggle="popover"
          data-bs-title="Right Popover"
          data-bs-content="Popover anchored to the right side."
          data-bs-placement="right">
          Right
        </button>
        <button type="button" class="btn btn-outline-secondary"
          data-bs-toggle="popover"
          data-bs-title="Dismissible"
          data-bs-content="Click anywhere outside to dismiss."
          data-bs-trigger="focus">
          Dismissible (focus)
        </button>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-pop">HTML</button>
        <button class="cb-tab" data-tab="js-pop">JS</button>
      </div>
      <pre is:raw id="html-pop"><code>&lt;button type="button" class="btn btn-primary"
  data-bs-toggle="popover"
  data-bs-title="Popover Title"
  data-bs-content="Popover body content here."
  data-bs-placement="top"&gt;
  Click me
&lt;/button&gt;

&lt;!-- Dismissible on focus-out --&gt;
&lt;button tabindex="0" class="btn btn-warning"
  data-bs-toggle="popover"
  data-bs-trigger="focus"
  data-bs-title="Dismissible"
  data-bs-content="Click outside to close."&gt;
  Focus dismissible
&lt;/button&gt;</code></pre>
      <pre is:raw id="js-pop" style="display:none"><code>// Initialize all popovers
const popoverEls = document.querySelectorAll('[data-bs-toggle="popover"]');
const popovers = [...popoverEls].map(el =&gt; new bootstrap.Popover(el));

// Single with options
const popover = new bootstrap.Popover(document.getElementById('myPop'), {
  placement: 'right',       // top | bottom | left | right | auto
  trigger: 'click',         // click | hover | focus | manual
  content: 'Dynamic content',
  html: true,
  sanitize: true,
});

popover.show();
popover.hide();
popover.toggle();
popover.dispose();</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
      document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => { new bootstrap.Popover(el); });

  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
