---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Tables" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Tables"
    description="Wrap &lt;table&gt; in .table. Combine modifiers: .table-striped, .table-hover, .table-bordered, .table-sm. Wrap in .table-responsive for scroll overflow."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;align-items:stretch">
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr><th>#</th><th>Name</th><th>Role</th><th>Status</th><th>Amount</th></tr>
            </thead>
            <tbody>
              <tr><td>1</td><td>Juan dela Cruz</td><td>Admin</td><td><span class="badge text-bg-success">Active</span></td><td>₱ 12,500</td></tr>
              <tr><td>2</td><td>Maria Santos</td><td>Manager</td><td><span class="badge text-bg-success">Active</span></td><td>₱ 9,800</td></tr>
              <tr><td>3</td><td>Pedro Reyes</td><td>Viewer</td><td><span class="badge text-bg-warning">Pending</span></td><td>₱ 6,400</td></tr>
              <tr><td>4</td><td>Ana Garcia</td><td>Viewer</td><td><span class="badge text-bg-danger">Inactive</span></td><td>₱ 0</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-table">HTML</button>
      </div>
      <pre is:raw id="html-table"><code>&lt;!-- Responsive wrapper --&gt;
&lt;div class="table-responsive"&gt;
  &lt;table class="table table-striped table-hover"&gt;
    &lt;thead&gt;
      &lt;tr&gt;
        &lt;th&gt;#&lt;/th&gt;
        &lt;th&gt;Name&lt;/th&gt;
        &lt;th&gt;Status&lt;/th&gt;
      &lt;/tr&gt;
    &lt;/thead&gt;
    &lt;tbody&gt;
      &lt;tr&gt;
        &lt;td&gt;1&lt;/td&gt;
        &lt;td&gt;Juan dela Cruz&lt;/td&gt;
        &lt;td&gt;&lt;span class="badge text-bg-success"&gt;Active&lt;/span&gt;&lt;/td&gt;
      &lt;/tr&gt;
    &lt;/tbody&gt;
  &lt;/table&gt;
&lt;/div&gt;

&lt;!-- Modifiers (combinable) --&gt;
&lt;table class="table"&gt;&lt;/table&gt;
&lt;table class="table table-striped"&gt;&lt;/table&gt;
&lt;table class="table table-bordered"&gt;&lt;/table&gt;
&lt;table class="table table-hover"&gt;&lt;/table&gt;
&lt;table class="table table-sm"&gt;&lt;/table&gt;
&lt;table class="table table-dark"&gt;&lt;/table&gt;</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
