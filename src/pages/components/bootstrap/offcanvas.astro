---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Offcanvas" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Offcanvas"
    description="Side panel that slides in from any edge. Use .offcanvas-start, .offcanvas-end, .offcanvas-top, or .offcanvas-bottom."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:8px">
        <button class="btn btn-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-start">Start (Left)</button>
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-end">End (Right)</button>
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="offcanvas" data-bs-target="#oc-bottom">Bottom</button>
      </div>
    </div>

    <!-- Offcanvas Start -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="oc-start" aria-labelledby="oc-start-label">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="oc-start-label">Left Panel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <p>This panel slides in from the left. Ideal for navigation menus or filter panels.</p>
        <ul class="list-group list-group-flush">
          <li class="list-group-item list-group-item-action">Dashboard</li>
          <li class="list-group-item list-group-item-action">Reports</li>
          <li class="list-group-item list-group-item-action">Settings</li>
        </ul>
      </div>
    </div>

    <!-- Offcanvas End -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="oc-end" aria-labelledby="oc-end-label">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="oc-end-label">Right Panel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <p>Slides from the right. Useful for detail views, shopping carts, or notification panels.</p>
      </div>
    </div>

    <!-- Offcanvas Bottom -->
    <div class="offcanvas offcanvas-bottom" tabindex="-1" id="oc-bottom" aria-labelledby="oc-bottom-label" style="height:200px">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="oc-bottom-label">Bottom Sheet</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">Slides up from the bottom. Suitable for mobile action sheets.</div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-oc">HTML</button>
        <button class="cb-tab" data-tab="js-oc">JS</button>
      </div>
      <pre is:raw id="html-oc"><code>&lt;!-- Trigger --&gt;
&lt;button class="btn btn-primary" type="button"
  data-bs-toggle="offcanvas"
  data-bs-target="#myOffcanvas"&gt;
  Open Panel
&lt;/button&gt;

&lt;!-- Offcanvas (positions: offcanvas-start | -end | -top | -bottom) --&gt;
&lt;div class="offcanvas offcanvas-start" tabindex="-1"
  id="myOffcanvas" aria-labelledby="myOffcanvasLabel"&gt;
  &lt;div class="offcanvas-header"&gt;
    &lt;h5 class="offcanvas-title" id="myOffcanvasLabel"&gt;Panel Title&lt;/h5&gt;
    &lt;button type="button" class="btn-close"
      data-bs-dismiss="offcanvas" aria-label="Close"&gt;&lt;/button&gt;
  &lt;/div&gt;
  &lt;div class="offcanvas-body"&gt;
    Panel content here.
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
      <pre is:raw id="js-oc" style="display:none"><code>const el = document.getElementById('myOffcanvas');
const oc = new bootstrap.Offcanvas(el, {
  backdrop: true, // true | false | 'static'
  keyboard: true,
  scroll: false,
});

oc.show();
oc.hide();
oc.toggle();

// Events
el.addEventListener('shown.bs.offcanvas', () =&gt; console.log('Panel open'));
el.addEventListener('hidden.bs.offcanvas', () =&gt; console.log('Panel closed'));</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
