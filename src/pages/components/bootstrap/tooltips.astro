---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Tooltips" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Tooltips"
    description="Small pop-up hints on hover/focus. Must be initialized via JS because they opt in to avoid performance overhead. Uses Popper.js for smart positioning."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:10px;align-items:center;flex-wrap:wrap">
        <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-title="Default tooltip (top)" data-bs-placement="top">Top</button>
        <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-title="Tooltip on right" data-bs-placement="right">Right</button>
        <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-title="Tooltip on bottom" data-bs-placement="bottom">Bottom</button>
        <button type="button" class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-title="Tooltip on left" data-bs-placement="left">Left</button>
        <button type="button" class="btn btn-primary" data-bs-toggle="tooltip" data-bs-html="true" data-bs-title="&lt;strong&gt;Bold&lt;/strong&gt; &lt;em&gt;HTML&lt;/em&gt; tooltip">HTML Tooltip</button>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-ttp">HTML</button>
        <button class="cb-tab" data-tab="js-ttp">JS</button>
      </div>
      <pre is:raw id="html-ttp"><code>&lt;!-- Add data attributes to any element --&gt;
&lt;button type="button" class="btn btn-secondary"
  data-bs-toggle="tooltip"
  data-bs-placement="top"
  data-bs-title="Tooltip text here"&gt;
  Hover me
&lt;/button&gt;

&lt;!-- HTML content in tooltip --&gt;
&lt;button data-bs-toggle="tooltip" data-bs-html="true"
  data-bs-title="&lt;strong&gt;Bold&lt;/strong&gt; text"&gt;
  HTML Tooltip
&lt;/button&gt;</code></pre>
      <pre is:raw id="js-ttp" style="display:none"><code>// Initialize all tooltips on the page
const tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
const tooltips = [...tooltipEls].map(el =&gt; new bootstrap.Tooltip(el));

// Single tooltip with options
const el = document.getElementById('myTooltip');
const tooltip = new bootstrap.Tooltip(el, {
  placement: 'top',        // top | bottom | left | right | auto
  trigger: 'hover focus',  // hover | focus | click | manual
  delay: { show: 100, hide: 0 },
  html: false,
});

tooltip.show();
tooltip.hide();
tooltip.dispose();</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => { new bootstrap.Tooltip(el); });

  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
