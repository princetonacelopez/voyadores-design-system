---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Spinners" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Spinners"
    description="Loading indicators in two styles: .spinner-border (ring) and .spinner-grow (pulse). Combine with .spinner-border-sm / .spinner-grow-sm for compact sizes."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:16px;align-items:center;flex-wrap:wrap">
        <div class="spinner-border" role="status"><span class="visually-hidden">Loading…</span></div>
        <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading…</span></div>
        <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading…</span></div>
        <div class="spinner-grow" role="status"><span class="visually-hidden">Loading…</span></div>
        <div class="spinner-grow text-warning" role="status"><span class="visually-hidden">Loading…</span></div>
        <div class="spinner-border spinner-border-sm" role="status"><span class="visually-hidden">Loading…</span></div>
        <button class="btn btn-primary" type="button" disabled>
          <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
          Loading…
        </button>
        <button class="btn btn-secondary" type="button" disabled>
          <span class="spinner-grow spinner-grow-sm me-1" role="status" aria-hidden="true"></span>
          Processing
        </button>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-spin">HTML</button>
      </div>
      <pre is:raw id="html-spin"><code>&lt;!-- Border spinner --&gt;
&lt;div class="spinner-border" role="status"&gt;
  &lt;span class="visually-hidden"&gt;Loading…&lt;/span&gt;
&lt;/div&gt;

&lt;!-- Grow spinner --&gt;
&lt;div class="spinner-grow" role="status"&gt;
  &lt;span class="visually-hidden"&gt;Loading…&lt;/span&gt;
&lt;/div&gt;

&lt;!-- Color variants --&gt;
&lt;div class="spinner-border text-primary"&gt;&lt;/div&gt;
&lt;div class="spinner-border text-success"&gt;&lt;/div&gt;
&lt;div class="spinner-border text-danger"&gt;&lt;/div&gt;

&lt;!-- Small --&gt;
&lt;div class="spinner-border spinner-border-sm"&gt;&lt;/div&gt;
&lt;div class="spinner-grow spinner-grow-sm"&gt;&lt;/div&gt;

&lt;!-- Button with spinner --&gt;
&lt;button class="btn btn-primary" type="button" disabled&gt;
  &lt;span class="spinner-border spinner-border-sm me-1"
    role="status" aria-hidden="true"&gt;&lt;/span&gt;
  Loading…
&lt;/button&gt;</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
