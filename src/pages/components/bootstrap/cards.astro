---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Cards" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Cards"
    description="Flexible content containers with header, body, and footer zones. Compose with images, list groups, and utilities."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:16px;align-items:flex-start;flex-wrap:wrap">
        <!-- Basic card -->
        <div class="card" style="width:220px">
          <div class="card-body">
            <h5 class="card-title">Card Title</h5>
            <p class="card-text">Quick example text to build on the card title.</p>
            <a href="#" class="btn btn-primary btn-sm">Go somewhere</a>
          </div>
        </div>
        <!-- Card with header + footer -->
        <div class="card" style="width:220px">
          <div class="card-header">Featured</div>
          <div class="card-body">
            <h5 class="card-title">Special title treatment</h5>
            <p class="card-text">With supporting text below as a natural lead-in.</p>
          </div>
          <div class="card-footer text-body-secondary">2 days ago</div>
        </div>
        <!-- List group card -->
        <div class="card" style="width:200px">
          <div class="card-header">Quick Links</div>
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Dashboard</li>
            <li class="list-group-item">Invoices</li>
            <li class="list-group-item">Reports</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-card">HTML</button>
      </div>
      <pre is:raw id="html-card"><code>&lt;!-- Basic card --&gt;
&lt;div class="card" style="width: 18rem"&gt;
  &lt;div class="card-body"&gt;
    &lt;h5 class="card-title"&gt;Card Title&lt;/h5&gt;
    &lt;p class="card-text"&gt;Quick example text.&lt;/p&gt;
    &lt;a href="#" class="btn btn-primary"&gt;Go somewhere&lt;/a&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Card with header + footer --&gt;
&lt;div class="card"&gt;
  &lt;div class="card-header"&gt;Featured&lt;/div&gt;
  &lt;div class="card-body"&gt;
    &lt;h5 class="card-title"&gt;Title&lt;/h5&gt;
    &lt;p class="card-text"&gt;Supporting text.&lt;/p&gt;
  &lt;/div&gt;
  &lt;div class="card-footer text-body-secondary"&gt;2 days ago&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Card with list group --&gt;
&lt;div class="card"&gt;
  &lt;div class="card-header"&gt;Quick Links&lt;/div&gt;
  &lt;ul class="list-group list-group-flush"&gt;
    &lt;li class="list-group-item"&gt;Dashboard&lt;/li&gt;
    &lt;li class="list-group-item"&gt;Invoices&lt;/li&gt;
  &lt;/ul&gt;
&lt;/div&gt;</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
