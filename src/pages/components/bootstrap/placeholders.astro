---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Placeholders" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Placeholders"
    description="Skeleton loading states. Replace content areas with .placeholder elements. Use .placeholder-glow or .placeholder-wave for animation."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:16px;align-items:flex-start;flex-wrap:wrap">
        <!-- Glow card skeleton -->
        <div class="card" style="width:220px">
          <div class="card-body">
            <p class="placeholder-glow">
              <span class="placeholder col-12" style="height:14px;border-radius:4px;display:block;margin-bottom:8px"></span>
              <span class="placeholder col-8"  style="height:14px;border-radius:4px;display:block;margin-bottom:8px"></span>
              <span class="placeholder col-10" style="height:14px;border-radius:4px;display:block;margin-bottom:16px"></span>
            </p>
            <a class="btn btn-primary disabled placeholder col-6" aria-disabled="true"></a>
          </div>
        </div>
        <!-- Wave card skeleton -->
        <div class="card" style="width:220px">
          <div class="card-body placeholder-wave">
            <h5 class="card-title placeholder-glow">
              <span class="placeholder col-7" style="border-radius:4px"></span>
            </h5>
            <p class="card-text placeholder-glow">
              <span class="placeholder col-12" style="border-radius:4px"></span>
              <span class="placeholder col-9"  style="border-radius:4px"></span>
            </p>
            <a class="btn btn-secondary disabled placeholder col-5" aria-disabled="true"></a>
          </div>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-ph">HTML</button>
      </div>
      <pre is:raw id="html-ph"><code>&lt;!-- Glow animation --&gt;
&lt;div class="card"&gt;
  &lt;div class="card-body"&gt;
    &lt;p class="placeholder-glow"&gt;
      &lt;span class="placeholder col-12"&gt;&lt;/span&gt;
      &lt;span class="placeholder col-8"&gt;&lt;/span&gt;
    &lt;/p&gt;
    &lt;a class="btn btn-primary disabled placeholder col-6"
      aria-disabled="true"&gt;&lt;/a&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Wave animation --&gt;
&lt;div class="placeholder-wave"&gt;
  &lt;span class="placeholder col-12"&gt;&lt;/span&gt;
  &lt;span class="placeholder col-9"&gt;&lt;/span&gt;
&lt;/div&gt;

&lt;!-- Size variants --&gt;
&lt;span class="placeholder placeholder-lg col-4"&gt;&lt;/span&gt;
&lt;span class="placeholder col-4"&gt;&lt;/span&gt;
&lt;span class="placeholder placeholder-sm col-4"&gt;&lt;/span&gt;
&lt;span class="placeholder placeholder-xs col-4"&gt;&lt;/span&gt;

&lt;!-- Color variants --&gt;
&lt;span class="placeholder bg-primary col-4"&gt;&lt;/span&gt;
&lt;span class="placeholder bg-success col-4"&gt;&lt;/span&gt;
&lt;span class="placeholder bg-danger col-4"&gt;&lt;/span&gt;</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
