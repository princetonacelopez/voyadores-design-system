---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Form Validation" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Form Validation"
    description="Use .is-valid / .is-invalid on inputs, or add .was-validated to the form for browser-based validation. Pair with .valid-feedback / .invalid-feedback."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;gap:12px;align-items:stretch;max-width:480px">
        <div class="mb-0">
          <label class="form-label">Valid input</label>
          <input type="text" class="form-control is-valid" value="Juan dela Cruz" />
          <div class="valid-feedback">Looks good!</div>
        </div>
        <div class="mb-0">
          <label class="form-label">Invalid input</label>
          <input type="text" class="form-control is-invalid" value="bad@" />
          <div class="invalid-feedback">Please enter a valid email address.</div>
        </div>
        <div class="mb-0">
          <label class="form-label">Invalid select</label>
          <select class="form-select is-invalid">
            <option value="">Choose…</option>
          </select>
          <div class="invalid-feedback">Please select an option.</div>
        </div>
        <div class="form-check">
          <input class="form-check-input is-invalid" type="checkbox" id="cbv" />
          <label class="form-check-label" for="cbv">Agree to terms</label>
          <div class="invalid-feedback">You must agree before submitting.</div>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-val">HTML</button>
        <button class="cb-tab" data-tab="js-val">JS</button>
      </div>
      <pre is:raw id="html-val"><code>&lt;!-- Valid state --&gt;
&lt;input type="text" class="form-control is-valid" /&gt;
&lt;div class="valid-feedback"&gt;Looks good!&lt;/div&gt;

&lt;!-- Invalid state --&gt;
&lt;input type="text" class="form-control is-invalid" /&gt;
&lt;div class="invalid-feedback"&gt;Please provide a valid value.&lt;/div&gt;

&lt;!-- Form-level (HTML5 validation) --&gt;
&lt;form class="needs-validation" novalidate&gt;
  &lt;div class="mb-3"&gt;
    &lt;label class="form-label"&gt;Name&lt;/label&gt;
    &lt;input type="text" class="form-control" required /&gt;
    &lt;div class="invalid-feedback"&gt;Name is required.&lt;/div&gt;
  &lt;/div&gt;
  &lt;button type="submit" class="btn btn-primary"&gt;Submit&lt;/button&gt;
&lt;/form&gt;</code></pre>
      <pre is:raw id="js-val" style="display:none"><code>// Bootstrap HTML5 validation pattern
(() =&gt; {
  const forms = document.querySelectorAll('.needs-validation');
  Array.from(forms).forEach(form =&gt; {
    form.addEventListener('submit', event =&gt; {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });
})();</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
