---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';

const containerTypes = [
  { cls: '.container',       desc: 'Responsive fixed-width — changes max-width at each VDS breakpoint.',  example: 'Default page layout' },
  { cls: '.container-sm',    desc: '100% width below sm (600px), then fixed above.',                      example: 'Narrow content, mobile-first' },
  { cls: '.container-md',    desc: '100% width below md (768px), then fixed above.',                      example: 'Tablet+ constrained content' },
  { cls: '.container-lg',    desc: '100% width below lg (1024px), then fixed above.',                     example: 'Full-bleed on small screens' },
  { cls: '.container-xl',    desc: '100% width below xl (1280px), then fixed above.',                     example: 'Wide dashboards' },
  { cls: '.container-xxl',   desc: '100% width below xxl (1440px), then fixed above.',                    example: 'Large monitor layouts' },
  { cls: '.container-fluid', desc: 'Always 100% width at every breakpoint.',                              example: 'Full-width hero sections, navbars' },
];

// VDS container max-widths (from bootstrap.voyadores.theme.css)
const maxWidths = [
  { bp: 'xs (<600px)',   container: '100%',   sm: '100%',   md: '100%',   lg: '100%',   xl: '100%',   xxl: '100%',  fluid: '100%' },
  { bp: 'sm (≥600px)',   container: '735px',  sm: '735px',  md: '100%',   lg: '100%',   xl: '100%',   xxl: '100%',  fluid: '100%' },
  { bp: 'md (≥768px)',   container: '959px',  sm: '959px',  md: '959px',  lg: '100%',   xl: '100%',   xxl: '100%',  fluid: '100%' },
  { bp: 'lg (≥1024px)',  container: '1199px', sm: '1199px', md: '1199px', lg: '1199px', xl: '100%',   xxl: '100%',  fluid: '100%' },
  { bp: 'xl (≥1280px)',  container: '1359px', sm: '1359px', md: '1359px', lg: '1359px', xl: '1359px', xxl: '100%',  fluid: '100%' },
  { bp: 'xxl (≥1440px)', container: '1800px', sm: '1800px', md: '1800px', lg: '1800px', xl: '1800px', xxl: '1800px', fluid: '100%' },
];
---

<BaseLayout title="Containers" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Containers"
    description="Containers are the foundational layout elements in the grid system. VDS uses custom breakpoints (sm=600px, lg=1024px, xl=1280px, xxl=1440px) — different from stock Bootstrap 5."
  />

  <!-- Types -->
  <div class="csec">
    <h2 class="csec-heading">Container Types</h2>
    <p class="csec-desc">Seven container variants to control horizontal padding and max-width at each breakpoint.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="display:block;padding:0">
        <table class="table table-bordered mb-0">
          <thead class="table-dark">
            <tr><th>Class</th><th>Description</th><th>Use case</th></tr>
          </thead>
          <tbody>
            {containerTypes.map(ct => (
              <tr>
                <td><code>{ct.cls}</code></td>
                <td style="font-size:13px">{ct.desc}</td>
                <td style="font-size:13px;color:#888">{ct.example}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Visual demo -->
  <div class="csec">
    <h2 class="csec-heading">Visual Comparison</h2>
    <p class="csec-desc">Visual comparison of container types at the current viewport width.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="display:block;padding:16px;overflow:hidden">
        {[
          ['container',       'bg-primary'],
          ['container-fluid', 'bg-success'],
          ['container-lg',    'bg-info'],
        ].map(([cls, bg]) => (
          <div class={`${cls} mb-2`}>
            <div class={`${bg} text-white text-center py-2 rounded`} style="font-size:12px;font-family:monospace">
              .{cls}
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="ct-html">HTML</button>
      </div>
      <pre is:raw id="ct-html"><code>&lt;div class="container"&gt;
  &lt;!-- Responsive fixed-width --&gt;
&lt;/div&gt;

&lt;div class="container-fluid"&gt;
  &lt;!-- Always 100% width --&gt;
&lt;/div&gt;

&lt;div class="container-lg"&gt;
  &lt;!-- 100% below lg, fixed on lg+ --&gt;
&lt;/div&gt;

&lt;div class="container-xxl"&gt;
  &lt;!-- 100% below xxl, 1320px on xxl --&gt;
&lt;/div&gt;</code></pre>
    </div>
  </div>

  <!-- Max-width reference -->
  <div class="csec">
    <h2 class="csec-heading">Max-Width Reference</h2>
    <p class="csec-desc">Max-width at each VDS breakpoint for all container variants. Note these differ from stock Bootstrap — sm starts at 600px, not 576px.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="display:block;padding:0;overflow-x:auto">
        <table class="table table-bordered table-sm mb-0" style="min-width:700px">
          <thead class="table-dark">
            <tr>
              <th>Breakpoint</th>
              <th>.container</th>
              <th>.container-sm</th>
              <th>.container-md</th>
              <th>.container-lg</th>
              <th>.container-xl</th>
              <th>.container-xxl</th>
              <th>.container-fluid</th>
            </tr>
          </thead>
          <tbody>
            {maxWidths.map(row => (
              <tr>
                <td><code>{row.bp}</code></td>
                <td style="color:#888">{row.container}</td>
                <td style="color:#888">{row.sm}</td>
                <td style="color:#888">{row.md}</td>
                <td style="color:#888">{row.lg}</td>
                <td style="color:#888">{row.xl}</td>
                <td style="color:#888">{row.xxl}</td>
                <td style="color:#077d55;font-weight:600">{row.fluid}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Nested containers -->
  <div class="csec">
    <h2 class="csec-heading">Nested in Sections</h2>
    <p class="csec-desc">Containers inside full-width sections — common pattern for page layouts.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="display:block;padding:0">
        <div style="background:#f0f4ff;padding:20px">
          <div class="container">
            <div class="py-3 px-4 bg-primary text-white rounded text-center" style="font-size:13px">
              .container inside a full-width section
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="ct-nested">HTML</button>
      </div>
      <pre is:raw id="ct-nested"><code>&lt;section class="bg-light py-5"&gt;
  &lt;div class="container"&gt;
    &lt;!-- Centered content with max-width --&gt;
    &lt;h2&gt;Section Heading&lt;/h2&gt;
    &lt;p&gt;Content constrained to container width.&lt;/p&gt;
  &lt;/div&gt;
&lt;/section&gt;</code></pre>
    </div>
  </div>

  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  .csec { margin-bottom: 56px; }
  .csec-heading { font-size: 16px; font-weight: 700; color: var(--black); margin: 0 0 8px; letter-spacing: -.01em; }
  .csec-desc { font-size: 13px; font-weight: 400; color: var(--g2); line-height: 1.7; margin-bottom: 16px; }
  .csec-desc code { font-family: var(--mono); font-size: .875em; background: var(--g5); padding: 1px 5px; border-radius: 3px; color: var(--g1); }
  .demo { margin-bottom: 16px; }
  .demo-preview { display: flex; flex-wrap: wrap; gap: 8px; padding: 28px; border: 1px solid var(--g5); border-radius: 4px; background: var(--white); align-items: center; }
  .code-block { background: #111; border-radius: 4px; overflow: hidden; }
  .cb-tabs { display: flex; border-bottom: 1px solid #2a2a2a; padding: 0 16px; }
  .cb-tab { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase; color: #666; background: none; border: none; padding: 10px 14px; border-bottom: 2px solid transparent; transition: color .12s, border-color .12s; }
  .cb-tab:hover { color: #ccc; }
  .cb-tab.is-on { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code { font-family: var(--mono); font-size: 12.5px; color: #e8e8e8; line-height: 1.85; white-space: pre; }
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
