---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="List Group" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="List Group"
    description="Flexible component for displaying series of content. Use .list-group-item-action for interactive items. Color variants with .list-group-item-*."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="gap:24px;align-items:flex-start;flex-wrap:wrap">
        <ul class="list-group" style="width:220px">
          <li class="list-group-item active" aria-current="true">Active item</li>
          <li class="list-group-item">Second item</li>
          <li class="list-group-item">Third item</li>
          <li class="list-group-item disabled" aria-disabled="true">Disabled item</li>
        </ul>
        <ul class="list-group" style="width:220px">
          <li class="list-group-item d-flex justify-content-between align-items-center">
            Inbox <span class="badge text-bg-primary rounded-pill">14</span>
          </li>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            Sent <span class="badge text-bg-primary rounded-pill">2</span>
          </li>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            Drafts <span class="badge text-bg-primary rounded-pill">1</span>
          </li>
        </ul>
        <ul class="list-group" style="width:220px">
          <li class="list-group-item list-group-item-primary">Primary item</li>
          <li class="list-group-item list-group-item-success">Success item</li>
          <li class="list-group-item list-group-item-danger">Danger item</li>
          <li class="list-group-item list-group-item-warning">Warning item</li>
        </ul>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-lg">HTML</button>
      </div>
      <pre is:raw id="html-lg"><code>&lt;!-- Basic --&gt;
&lt;ul class="list-group"&gt;
  &lt;li class="list-group-item active" aria-current="true"&gt;Active item&lt;/li&gt;
  &lt;li class="list-group-item"&gt;Second item&lt;/li&gt;
  &lt;li class="list-group-item disabled" aria-disabled="true"&gt;Disabled&lt;/li&gt;
&lt;/ul&gt;

&lt;!-- With badges --&gt;
&lt;ul class="list-group"&gt;
  &lt;li class="list-group-item d-flex justify-content-between align-items-center"&gt;
    Inbox
    &lt;span class="badge text-bg-primary rounded-pill"&gt;14&lt;/span&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;!-- Color variants --&gt;
&lt;ul class="list-group"&gt;
  &lt;li class="list-group-item list-group-item-primary"&gt;Primary&lt;/li&gt;
  &lt;li class="list-group-item list-group-item-success"&gt;Success&lt;/li&gt;
  &lt;li class="list-group-item list-group-item-danger"&gt;Danger&lt;/li&gt;
  &lt;li class="list-group-item list-group-item-warning"&gt;Warning&lt;/li&gt;
&lt;/ul&gt;</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
