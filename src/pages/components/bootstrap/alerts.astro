---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Alerts" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Alerts"
    description="Contextual feedback messages. Dismissible with .alert-dismissible. Use Bootstrap JS to close programmatically."
  />

  <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;gap:8px;align-items:stretch">
        <div class="alert alert-primary" role="alert">A simple <strong>primary</strong> alert with example text.</div>
        <div class="alert alert-success" role="alert"><strong>Success!</strong> Your changes have been saved.</div>
        <div class="alert alert-danger" role="alert"><strong>Error!</strong> Something went wrong. Please try again.</div>
        <div class="alert alert-warning" role="alert"><strong>Warning!</strong> This action cannot be undone.</div>
        <div class="alert alert-info" role="alert">For your information: new features are now available.</div>
        <div class="alert alert-primary alert-dismissible fade show" role="alert">
          <strong>Dismissible alert.</strong> Click the × to close.
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
    </div>

    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="html-alert">HTML</button>
        <button class="cb-tab" data-tab="js-alert">JS</button>
      </div>
      <pre is:raw id="html-alert"><code>&lt;div class="alert alert-primary" role="alert"&gt;Primary alert&lt;/div&gt;
&lt;div class="alert alert-success" role="alert"&gt;Success alert&lt;/div&gt;
&lt;div class="alert alert-danger"  role="alert"&gt;Danger alert&lt;/div&gt;
&lt;div class="alert alert-warning" role="alert"&gt;Warning alert&lt;/div&gt;
&lt;div class="alert alert-info"    role="alert"&gt;Info alert&lt;/div&gt;

&lt;!-- Dismissible --&gt;
&lt;div class="alert alert-primary alert-dismissible fade show" role="alert"&gt;
  Dismissible alert content.
  &lt;button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"&gt;&lt;/button&gt;
&lt;/div&gt;</code></pre>
      <pre is:raw id="js-alert" style="display:none"><code>// Programmatic dismiss
const alertEl = document.querySelector('.alert');
const bsAlert = bootstrap.Alert.getOrCreateInstance(alertEl);
bsAlert.close();

// Listen for close event
alertEl.addEventListener('closed.bs.alert', () =&gt; {
  console.log('Alert was closed');
});</code></pre>
    </div>

  <!-- Bootstrap JS bundle (Popper included) -->
  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>

  <script>
      // Code tabs
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  /* Sections */
  .csec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .csec-desc {
    font-size: 13px; font-weight: 400; color: var(--g2);
    line-height: 1.7; margin-bottom: 20px;
  }
  .csec-desc code {
    font-family: var(--mono); font-size: .875em;
    background: var(--g5); padding: 1px 5px; border-radius: 3px;
    color: var(--g1);
  }

  /* Demo box */
  .demo { margin-bottom: 16px; }
  .demo-preview {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 28px; border: 1px solid var(--g5);
    border-radius: 4px; background: var(--white);
    align-items: center;
  }

  /* Code block */
  .code-block {
    background: #111; border-radius: 4px; overflow: hidden;
  }
  .cb-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid #2a2a2a; padding: 0 16px;
  }
  .cb-tab {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: .04em; text-transform: uppercase;
    color: #666; background: none; border: none;
    padding: 10px 14px; border-bottom: 2px solid transparent;
    transition: color .12s, border-color .12s;
  }
  .cb-tab:hover  { color: #ccc; }
  .cb-tab.is-on  { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code {
    font-family: var(--mono); font-size: 12.5px;
    color: #e8e8e8; line-height: 1.85; white-space: pre;
  }

  /* Override Bootstrap base styles to protect site layout */
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
