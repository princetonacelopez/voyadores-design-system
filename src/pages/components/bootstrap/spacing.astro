---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
---

<BaseLayout title="Spacing" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Bootstrap"
    title="Spacing"
    description="Bootstrap includes margin and padding utilities for all sides, axes, and responsive breakpoints. Format: &#123;property&#125;&#123;sides&#125;-&#123;size&#125; or &#123;property&#125;&#123;sides&#125;-&#123;breakpoint&#125;-&#123;size&#125;."
  />

  <!-- Scale reference -->
  <div class="csec">
    <h2 class="csec-heading">Spacing Scale</h2>
    <p class="csec-desc">The VDS spacing scale extends Bootstrap's default 0–5 to <strong>0–10</strong>, giving finer control at small sizes and larger steps for page-level layout. All values use rem units at a 16px base.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="display:block;padding:0">
        <table class="table table-bordered table-sm mb-0">
          <thead class="table-dark">
            <tr><th>Suffix</th><th>Value</th><th>Pixels</th><th>Visual</th></tr>
          </thead>
          <tbody>
            {[
              ['0',  '0',        '0px',   0],
              ['1',  '0.125rem', '2px',   2],
              ['2',  '0.25rem',  '4px',   4],
              ['3',  '0.5rem',   '8px',   8],
              ['4',  '0.75rem',  '12px',  12],
              ['5',  '1rem',     '16px',  16],
              ['6',  '1.5rem',   '24px',  24],
              ['7',  '2rem',     '32px',  32],
              ['8',  '2.5rem',   '40px',  40],
              ['9',  '3rem',     '48px',  48],
              ['10', '4rem',     '64px',  64],
            ].map(([s, v, p, px]) => (
              <tr>
                <td><code>-{s}</code></td>
                <td><code>{v}</code></td>
                <td>{p}</td>
                <td>
                  {px > 0
                    ? <div style={`height:8px;background:var(--brand);border-radius:2px;width:${Math.min(px * 2, 200)}px`}></div>
                    : <span style="color:#aaa;font-size:11px">—</span>
                  }
                </td>
              </tr>
            ))}
            <tr><td><code>-auto</code></td><td><code>auto</code></td><td>auto</td><td><span style="color:#aaa;font-size:11px">—</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Margin -->
  <div class="csec">
    <h2 class="csec-heading">Margin</h2>
    <p class="csec-desc">
      <strong>Margin</strong>: <code>m&#123;sides&#125;-&#123;size&#125;</code> — sides: blank (all), t, b, s, e, x, y
    </p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;align-items:flex-start;gap:0;padding:16px">
        {[
          ['m-3',   'All sides — 0.5rem (8px)'],
          ['m-5',   'All sides — 1rem (16px)'],
          ['mt-6',  'Top — 1.5rem (24px)'],
          ['mb-3',  'Bottom — 0.5rem (8px)'],
          ['ms-7',  'Start (left) — 2rem (32px)'],
          ['me-5',  'End (right) — 1rem (16px)'],
          ['mx-6',  'Horizontal (left+right) — 1.5rem'],
          ['my-5',  'Vertical (top+bottom) — 1rem'],
          ['ms-auto','Start auto — pushes to right in flex'],
          ['mx-auto','Horizontal auto — centers a block'],
        ].map(([cls, desc]) => (
          <div class="mb-2" style="font-size:13px;display:flex;align-items:center;gap:12px">
            <code style="min-width:100px">.{cls}</code>
            <span style="color:#666">{desc}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="sp-margin">HTML</button>
      </div>
      <pre is:raw id="sp-margin"><code>&lt;div class="m-5"&gt;All margins 1rem&lt;/div&gt;
&lt;div class="mt-6 mb-3"&gt;Top 1.5rem, bottom 0.5rem&lt;/div&gt;
&lt;div class="mx-auto" style="max-width:300px"&gt;Centered block&lt;/div&gt;
&lt;div class="ms-auto"&gt;Pushed to the right (in flex)&lt;/div&gt;

&lt;!-- Available margin sides --&gt;
&lt;!-- m   = all sides          --&gt;
&lt;!-- mt  = top                --&gt;
&lt;!-- mb  = bottom             --&gt;
&lt;!-- ms  = start (left in LTR)--&gt;
&lt;!-- me  = end (right in LTR) --&gt;
&lt;!-- mx  = left + right       --&gt;
&lt;!-- my  = top + bottom       --&gt;</code></pre>
    </div>
  </div>

  <!-- Padding -->
  <div class="csec">
    <h2 class="csec-heading">Padding</h2>
    <p class="csec-desc">
      <strong>Padding</strong>: <code>p&#123;sides&#125;-&#123;size&#125;</code> — same side notation as margin.
    </p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="gap:10px;flex-wrap:wrap;align-items:flex-end">
        {['p-2','p-3','p-4','p-5','p-6','p-7','p-8','p-9','p-10'].map(cls => (
          <div class={`bg-primary text-white rounded ${cls}`} style="font-size:10px;font-family:monospace;white-space:nowrap">.{cls}</div>
        ))}
      </div>
    </div>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="sp-padding">HTML</button>
      </div>
      <pre is:raw id="sp-padding"><code>&lt;div class="p-5"&gt;All padding 1rem&lt;/div&gt;
&lt;div class="pt-6 pb-3"&gt;Top 1.5rem, bottom 0.5rem&lt;/div&gt;
&lt;div class="px-6 py-3"&gt;Horizontal 1.5rem, vertical 0.5rem&lt;/div&gt;
&lt;div class="ps-5 pe-7"&gt;Start 1rem, end 2rem&lt;/div&gt;

&lt;!-- Available padding sides --&gt;
&lt;!-- p   = all sides          --&gt;
&lt;!-- pt  = top                --&gt;
&lt;!-- pb  = bottom             --&gt;
&lt;!-- ps  = start (left in LTR)--&gt;
&lt;!-- pe  = end (right in LTR) --&gt;
&lt;!-- px  = left + right       --&gt;
&lt;!-- py  = top + bottom       --&gt;</code></pre>
    </div>
  </div>

  <!-- Gap utilities -->
  <div class="csec">
    <h2 class="csec-heading">Gap</h2>
    <p class="csec-desc"><strong>Gap</strong>: <code>gap-&#123;size&#125;</code>, <code>row-gap-&#123;size&#125;</code>, <code>column-gap-&#123;size&#125;</code> — use on flex or grid containers.</p>
    <div class="demo">
      <div class="demo-preview bs-scope" style="flex-direction:column;gap:16px">
        {['gap-2','gap-3','gap-5','gap-6','gap-7','gap-8'].map(cls => (
          <div style="display:flex;align-items:center;gap:12px">
            <code style="font-size:11px;min-width:72px">.{cls}</code>
            <div class={`d-flex ${cls}`}>
              {['A','B','C'].map(l => (
                <div class="bg-secondary text-white px-3 py-1 rounded" style="font-size:12px">{l}</div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="sp-gap">HTML</button>
      </div>
      <pre is:raw id="sp-gap"><code>&lt;!-- Gap in flex --&gt;
&lt;div class="d-flex gap-5"&gt;
  &lt;div&gt;Item 1&lt;/div&gt;
  &lt;div&gt;Item 2&lt;/div&gt;
  &lt;div&gt;Item 3&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Gap in Bootstrap grid (g-* maps to gap-*) --&gt;
&lt;div class="row g-5"&gt;
  &lt;div class="col-4"&gt;Col 1&lt;/div&gt;
  &lt;div class="col-4"&gt;Col 2&lt;/div&gt;
  &lt;div class="col-4"&gt;Col 3&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Row and column gap independently --&gt;
&lt;div class="d-grid row-gap-3 column-gap-6"&gt;...&lt;/div&gt;</code></pre>
    </div>
  </div>

  <!-- Responsive spacing -->
  <div class="csec">
    <h2 class="csec-heading">Responsive Spacing</h2>
    <p class="csec-desc">Add a breakpoint infix to apply spacing only at that viewport size and above.</p>
    <div class="code-block">
      <div class="cb-tabs">
        <button class="cb-tab is-on" data-tab="sp-responsive">HTML</button>
      </div>
      <pre is:raw id="sp-responsive"><code>&lt;!-- Small margin on mobile, larger on desktop --&gt;
&lt;div class="mt-3 mt-md-6 mt-lg-8"&gt;
  &lt;!-- mt-3=0.5rem on xs, mt-6=1.5rem on md+, mt-8=2.5rem on lg+ --&gt;
&lt;/div&gt;

&lt;!-- No padding on xs, padding on sm+ --&gt;
&lt;div class="p-0 p-sm-5"&gt;...&lt;/div&gt;

&lt;!-- Responsive horizontal padding (page gutters) --&gt;
&lt;div class="px-4 px-md-6 px-lg-0 mx-auto" style="max-width:720px"&gt;...&lt;/div&gt;

&lt;!-- Stack vertically on mobile, add row gap on desktop --&gt;
&lt;div class="d-flex flex-column flex-md-row gap-3 gap-md-6"&gt;
  &lt;div&gt;Item 1&lt;/div&gt;
  &lt;div&gt;Item 2&lt;/div&gt;
&lt;/div&gt;</code></pre>
    </div>
  </div>

  <script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelectorAll('.cb-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const block  = btn.closest('.code-block');
        block.querySelectorAll('.cb-tab').forEach(b => b.classList.remove('is-on'));
        block.querySelectorAll('pre').forEach(p => p.style.display = 'none');
        btn.classList.add('is-on');
        const pre = document.getElementById(target);
        if (pre) pre.style.display = '';
      });
    });
  </script>
</BaseLayout>

<style>
  .csec { margin-bottom: 56px; }
  .csec-heading { font-size: 16px; font-weight: 700; color: var(--black); margin: 0 0 8px; letter-spacing: -.01em; }
  .csec-desc { font-size: 13px; font-weight: 400; color: var(--g2); line-height: 1.7; margin-bottom: 16px; }
  .csec-desc code { font-family: var(--mono); font-size: .875em; background: var(--g5); padding: 1px 5px; border-radius: 3px; color: var(--g1); }
  .csec-desc strong { color: var(--black); }
  .demo { margin-bottom: 16px; }
  .demo-preview { display: flex; flex-wrap: wrap; gap: 8px; padding: 28px; border: 1px solid var(--g5); border-radius: 4px; background: var(--white); align-items: center; }
  .code-block { background: #111; border-radius: 4px; overflow: hidden; }
  .cb-tabs { display: flex; border-bottom: 1px solid #2a2a2a; padding: 0 16px; }
  .cb-tab { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: .04em; text-transform: uppercase; color: #666; background: none; border: none; padding: 10px 14px; border-bottom: 2px solid transparent; transition: color .12s, border-color .12s; }
  .cb-tab:hover { color: #ccc; }
  .cb-tab.is-on { color: var(--brand); border-bottom-color: var(--brand); }
  .code-block pre { margin: 0; padding: 20px 24px; overflow-x: auto; }
  .code-block code { font-family: var(--mono); font-size: 12.5px; color: #e8e8e8; line-height: 1.85; white-space: pre; }
  .bs-scope * { cursor: auto !important; }
  .bs-scope { font-family: var(--vds-font-sans-serif, "Lexend", sans-serif); }
</style>
