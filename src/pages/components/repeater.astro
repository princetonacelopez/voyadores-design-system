---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="Repeater" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Others"
    title="Repeater"
    description="A jQuery plugin that renders a list of items from a data array or AJAX endpoint using a custom mapping function. Supports dynamic add/remove, empty states, and error states."
  />

  <section class="sec">
    <h2>Setup</h2>
    <div class="code-block"><pre is:raw><code>&lt;script src="https://cdn.voyadores.com/content/js/jquery/jquery-3.6.0.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.voyadores.com/content/js/repeater/repeater-1-6-1.min.js"&gt;&lt;/script&gt;</code></pre></div>
  </section>

  <section class="sec">
    <h2>Demo</h2>
    <div class="demo-area bs-scope">
      <div class="add-row">
        <input type="text"  id="inp-name"  class="form-control form-control-sm" placeholder="Full name" />
        <input type="email" id="inp-email" class="form-control form-control-sm" placeholder="Email" />
        <select id="inp-role" class="form-select form-select-sm">
          <option value="">Role&hellip;</option>
          <option>Admin</option>
          <option>Editor</option>
          <option>Viewer</option>
        </select>
        <button id="btn-add" class="btn btn-sm btn-primary">Add Contact</button>
      </div>
      <div id="demo-repeater"></div>
    </div>
  </section>

  <section class="sec">
    <h2>Usage</h2>
    <div class="code-block"><pre is:raw><code>// Static data — plugin renders via mappingFunction
$('#my-container').repeater({
  data: [
    { name: 'Ana Reyes', role: 'Admin'  },
    { name: 'Ben Cruz',  role: 'Editor' },
  ],
  mappingFunction: function (data) {
    return data.map(function (item) {
      return '&lt;div class="item"&gt;' + item.name + ' — ' + item.role + '&lt;/div&gt;';
    }).join('');
  },
  success: function (data) { console.log('Rendered', data.length, 'items'); },
});

// AJAX endpoint
$('#my-container').repeater({
  endpoint: '/api/contacts',
  type: 'GET',
  params: { companyId: 1 },
  mappingFunction: function (data) { return data.map(fn).join(''); },
  success: function (data) {},
  fail:    function (err)  {},
});

// Commands
$('#my-container').repeater('refresh');                // re-fetch from endpoint
$('#my-container').repeater('refreshData', newArray);  // replace with new array
$('#my-container').repeater('clear');                  // empty the container</code></pre></div>
  </section>
</BaseLayout>

<script is:inline src="/js/jquery/jquery-3.6.0.min.js"></script>
<script is:inline src="/js/repeater/repeater-1-6-1.min.js"></script>
<script is:inline>
$(function () {
  var contacts = [
    { name: 'Ana Reyes',     email: 'ana.reyes@example.com',     role: 'Admin'  },
    { name: 'Ben Cruz',      email: 'ben.cruz@example.com',       role: 'Editor' },
    { name: 'Carlo Tan',     email: 'carlo.tan@example.com',      role: 'Viewer' },
  ];

  var roleBadge = {
    'Admin':  '<span class="badge bg-danger">Admin</span>',
    'Editor': '<span class="badge bg-primary">Editor</span>',
    'Viewer': '<span class="badge bg-secondary">Viewer</span>',
  };

  function mapContacts(data) {
    return data.map(function (item, idx) {
      return '<div class="rp-row">' +
        '<div class="rp-info">' +
          '<span class="rp-name">' + item.name + '</span>' +
          '<span class="rp-email">' + item.email + '</span>' +
        '</div>' +
        '<div class="rp-meta">' + (roleBadge[item.role] || item.role) + '</div>' +
        '<button type="button" class="rp-remove" data-idx="' + idx + '" title="Remove">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button>' +
      '</div>';
    }).join('');
  }

  $('#demo-repeater').repeater({ data: contacts, mappingFunction: mapContacts });

  $('#demo-repeater').on('click', '.rp-remove', function () {
    contacts.splice(parseInt($(this).data('idx')), 1);
    $('#demo-repeater').repeater('refreshData', contacts);
  });

  $('#btn-add').on('click', function () {
    var name  = $('#inp-name').val().trim();
    var email = $('#inp-email').val().trim();
    var role  = $('#inp-role').val();
    if (!name || !email || !role) { alert('Please fill in all fields.'); return; }
    contacts.push({ name: name, email: email, role: role });
    $('#demo-repeater').repeater('refreshData', contacts);
    $('#inp-name').val(''); $('#inp-email').val(''); $('#inp-role').val('');
  });
});
</script>

<style>
  .sec { margin-bottom: 56px; }
  .sec h2 { font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5); }
  .demo-area { padding: 24px; border: 1px solid var(--g5); border-radius: 2px; background: var(--white); }
  .bs-scope { cursor: auto; }

  .add-row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--g5); }
  .add-row .form-control, .add-row .form-select { flex: 1; min-width: 120px; }

  .rp-row { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid var(--g5); border-radius: 6px; margin-bottom: 8px; background: var(--g6); }
  .rp-row:last-child { margin-bottom: 0; }
  .rp-info { flex: 1; min-width: 0; }
  .rp-name { display: block; font-size: 13px; font-weight: 600; color: var(--black); }
  .rp-email { display: block; font-size: 11px; color: var(--g2); margin-top: 1px; }
  .rp-meta { flex-shrink: 0; }
  .rp-remove { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; flex-shrink: 0; background: none; border: 1px solid var(--g5); border-radius: 4px; color: var(--g2); cursor: pointer; transition: border-color .12s, color .12s; }
  .rp-remove:hover { border-color: #d91f11; color: #d91f11; }
</style>
