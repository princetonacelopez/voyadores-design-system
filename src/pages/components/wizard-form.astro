---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="Wizard Form" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Others"
    title="Wizard Form"
    description="Multi-step form wizard with step validation, progress tracking, and per-step lifecycle callbacks. Designed to run inside a Bootstrap modal."
  />

  <section class="sec">
    <h2>Setup</h2>
    <div class="code-block"><pre is:raw><code>&lt;script type="module"&gt;
import WizardForm from 'https://cdn.voyadores.com/content/js/wizard-form/wizard-form.min.js';
&lt;/script&gt;</code></pre></div>
  </section>

  <section class="sec">
    <h2>Demo</h2>
    <div class="demo-area bs-scope">
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#wizardModal">
        Open Wizard Form
      </button>

      <!-- Modal -->
      <div class="modal fade" id="wizardModal" tabindex="-1" aria-labelledby="wizardModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="wizardModalLabel">New Employee Onboarding</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
              <!-- Wizard container -->
              <div id="demo-wizard" class="wz-container">
                <div class="wz-progress-wrap">
                  <progress class="progress-bar" value="33" max="100"></progress>
                  <ul class="progress-indicator"></ul>
                </div>
                <div class="wizard-content px-4 pb-2">
                  <div class="wizard-step active">
                    <p class="wz-step-label">Personal Information</p>
                    <div class="field-group">
                      <label class="form-label">Full Name</label>
                      <input type="text" id="wz-name" class="form-control" placeholder="Juan dela Cruz" />
                    </div>
                    <div class="field-group">
                      <label class="form-label">Email</label>
                      <input type="email" id="wz-email" class="form-control" placeholder="juan@example.com" />
                    </div>
                  </div>
                  <div class="wizard-step">
                    <p class="wz-step-label">Role & Department</p>
                    <div class="field-group">
                      <label class="form-label">Department</label>
                      <select id="wz-dept" class="form-select">
                        <option value="">Select…</option>
                        <option value="hr">Human Resources</option>
                        <option value="it">Information Technology</option>
                        <option value="fin">Finance</option>
                        <option value="ops">Operations</option>
                      </select>
                    </div>
                    <div class="field-group">
                      <label class="form-label">Job Title</label>
                      <input type="text" id="wz-title" class="form-control" placeholder="Software Engineer" />
                    </div>
                  </div>
                  <div class="wizard-step">
                    <p class="wz-step-label">Review &amp; Submit</p>
                    <div id="wz-summary" class="wz-summary"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="modal-footer wizard-navigation">
              <button type="button" class="btn btn-outline-secondary prev-button">Back</button>
              <button type="button" class="btn btn-primary next-button">Next</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="sec">
    <h2>Usage</h2>
    <div class="code-block"><pre is:raw><code>import WizardForm from 'https://cdn.voyadores.com/content/js/wizard-form/wizard-form.min.js';

// HTML must be inside .modal-content
// #my-wizard needs: .progress-bar, .progress-indicator, .wizard-content &gt; .wizard-step
// .wizard-navigation needs: .prev-button, .next-button

const wizard = new WizardForm('#my-wizard', {
  steps: [
    {
      title: 'Personal Info',
      onEnter: () =&gt; { /* called when entering step */ },
      onNext: (next) =&gt; {
        // validate, then call next() to advance
        if (!name.value) return alert('Name is required');
        next();
      },
    },
    {
      title: 'Role',
      onNext: (next) =&gt; { next(); },
    },
    {
      title: 'Review',
      onFinish: () =&gt; {
        // submit logic
        console.log('Form submitted');
      },
    },
  ],
  finishButtonText: 'Submit',
  allowPrevious: true,
});</code></pre></div>
  </section>
</BaseLayout>

<script is:inline src="/js/bootstrap/bootstrap.bundle.min.js"></script>
<script is:inline type="module">
import WizardForm from '/js/wizard-form/wizard-form.min.js';

document.getElementById('wizardModal').addEventListener('shown.bs.modal', function () {
  var nameEl  = document.getElementById('wz-name');
  var emailEl = document.getElementById('wz-email');
  var deptEl  = document.getElementById('wz-dept');
  var titleEl = document.getElementById('wz-title');
  var summary = document.getElementById('wz-summary');

  var wizard = new WizardForm('#demo-wizard', {
    steps: [
      {
        title: 'Personal Info',
        onNext: function (next) {
          if (!nameEl.value.trim()) { nameEl.focus(); return; }
          if (!emailEl.value.trim()) { emailEl.focus(); return; }
          next();
        },
      },
      {
        title: 'Role & Dept',
        onNext: function (next) { next(); },
      },
      {
        title: 'Review',
        onEnter: function () {
          summary.innerHTML =
            '<dl class="wz-dl">' +
            '<dt>Name</dt><dd>' + (nameEl.value || '—') + '</dd>' +
            '<dt>Email</dt><dd>' + (emailEl.value || '—') + '</dd>' +
            '<dt>Department</dt><dd>' + (deptEl.options[deptEl.selectedIndex]?.text || '—') + '</dd>' +
            '<dt>Job Title</dt><dd>' + (titleEl.value || '—') + '</dd>' +
            '</dl>';
        },
        onFinish: function () {
          var modal = bootstrap.Modal.getInstance(document.getElementById('wizardModal'));
          if (modal) modal.hide();
          alert('Onboarding form submitted!');
        },
      },
    ],
    finishButtonText: 'Submit',
    allowPrevious: true,
  });
});
</script>

<style>
  .sec { margin-bottom: 56px; }
  .sec h2 { font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5); }
  .code-block { background: #161616; border-radius: 4px; overflow: auto; }
  .code-block pre { margin: 0; padding: 20px 24px; }
  .code-block code { font-family: var(--mono); font-size: 13px; color: #f5f5f5; line-height: 1.8; white-space: pre; }
  .demo-area { padding: 24px; border: 1px solid var(--g5); border-radius: 2px; background: var(--white); }
  .bs-scope { cursor: auto; }
  .field-group { margin-bottom: 16px; }

  /* Wizard progress */
  .wz-container { padding: 20px 0 0; }
  .wz-progress-wrap { padding: 0 24px 12px; border-bottom: 1px solid var(--g5); }
  .progress-bar { width: 100%; height: 4px; appearance: none; border: none; border-radius: 99px; background: var(--g5); margin-bottom: 12px; }
  .progress-bar::-webkit-progress-bar { background: var(--g5); border-radius: 99px; }
  .progress-bar::-webkit-progress-value { background: var(--brand); border-radius: 99px; transition: width .3s; }
  .progress-bar::-moz-progress-bar { background: var(--brand); border-radius: 99px; }
  .progress-indicator { display: flex; gap: 12px; list-style: none; padding: 0; margin: 0; }
  .progress-indicator .progress-step { display: flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 500; color: var(--g3); }
  .progress-indicator .progress-step.active { color: var(--brand); font-weight: 600; }
  .progress-indicator .progress-step.completed { color: var(--g2); }

  /* Wizard step */
  .wizard-step { display: none; }
  .wizard-step.active { display: block; }
  .wz-step-label { font-size: 13px; font-weight: 600; color: var(--black); margin-bottom: 16px; padding-top: 4px; }

  /* Summary */
  .wz-summary { background: var(--g6); border-radius: 4px; padding: 16px; }
  .wz-dl { display: grid; grid-template-columns: 120px 1fr; gap: 8px 12px; margin: 0; }
  .wz-dl dt { font-size: 11px; font-weight: 600; color: var(--g2); text-transform: uppercase; letter-spacing: .05em; }
  .wz-dl dd { font-size: 13px; color: var(--black); margin: 0; }
</style>
