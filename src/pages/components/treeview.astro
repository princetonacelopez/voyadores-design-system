---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="Treeview" activeSection="components">
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/bootstrap/bootstrap.voyadores.theme.min.css" />
    <link rel="stylesheet" href="/css/treeview/treeview-1-0-0.min.css" />
  </Fragment>

  <PageHeader
    eyebrow="Components / Others"
    title="Treeview"
    description="jQuery-based hierarchical tree component with expandable/collapsible nodes, AJAX or static data loading, and custom action buttons per node."
  />

  <section class="sec">
    <h2>Setup</h2>
    <div class="code-block"><pre is:raw><code>&lt;link rel="stylesheet" href="https://cdn.voyadores.com/content/css/treeview/treeview-1-0-0.min.css" /&gt;

&lt;script src="https://cdn.voyadores.com/content/js/jquery/jquery-3.6.0.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.voyadores.com/content/js/treeview/treeview-1-0-0.min.js"&gt;&lt;/script&gt;</code></pre></div>
  </section>

  <section class="sec">
    <h2>Demo</h2>
    <div class="demo-area bs-scope">
      <div id="demo-tree"></div>
    </div>
  </section>

  <section class="sec">
    <h2>Usage</h2>
    <div class="code-block"><pre is:raw><code>// Data uses nested { id, rootId, text, nodes } format
$('#my-tree').treeview({
  treeHeader: 'Chart of Accounts',
  data: [
    {
      id: 1, rootId: 1, text: 'Assets', nodes: [
        {
          id: 2, rootId: 1, text: 'Current Assets', nodes: [
            { id: 3, rootId: 1, text: 'Cash', nodes: [] },
          ]
        },
      ]
    },
    { id: 4, rootId: 4, text: 'Liabilities', nodes: [] },
  ],
  collapseOnLoad: false,
  actions: [
    {
      button: function (id, rootId, text) {
        return '&lt;button class="btn btn-sm tv-edit" data-id="' + id + '" data-root-id="' + rootId + '" data-text="' + text + '"&gt;Edit&lt;/button&gt;';
      },
      buttonSelector: '.tv-edit',
      onClick: function (params, e) { console.log('edit', params); },
    },
  ],
});

// Remote data
$('#my-tree').treeview({
  treeHeader: 'Accounts',
  endpoint: '/api/accounts',
  type: 'GET',
  params: { companyId: 1 },
  onSuccess: function (data) { console.log('Loaded', data); },
  onFailure: function (err)  { console.error(err); },
});

// Refresh
$('#my-tree').treeview('refresh', { companyId: 2 });</code></pre></div>
  </section>
</BaseLayout>

<script is:inline src="/js/jquery/jquery-3.6.0.min.js"></script>
<script is:inline src="/js/treeview/treeview-1-0-0.min.js"></script>
<script is:inline>
$(function () {
  var data = [
    {
      id: 1, rootId: 1, text: 'Assets', nodes: [
        {
          id: 2, rootId: 1, text: 'Current Assets', nodes: [
            { id: 3,  rootId: 1, text: 'Cash and Cash Equivalents', nodes: [] },
            { id: 4,  rootId: 1, text: 'Accounts Receivable',       nodes: [] },
            { id: 5,  rootId: 1, text: 'Inventories',               nodes: [] },
          ]
        },
        {
          id: 6, rootId: 1, text: 'Non-current Assets', nodes: [
            { id: 7,  rootId: 1, text: 'Property & Equipment', nodes: [] },
            { id: 8,  rootId: 1, text: 'Intangible Assets',    nodes: [] },
          ]
        },
      ]
    },
    {
      id: 9, rootId: 9, text: 'Liabilities', nodes: [
        {
          id: 10, rootId: 9, text: 'Current Liabilities', nodes: [
            { id: 11, rootId: 9, text: 'Accounts Payable', nodes: [] },
            { id: 12, rootId: 9, text: 'Accrued Expenses', nodes: [] },
          ]
        },
      ]
    },
    {
      id: 13, rootId: 13, text: 'Equity', nodes: [
        { id: 14, rootId: 13, text: 'Share Capital',      nodes: [] },
        { id: 15, rootId: 13, text: 'Retained Earnings',  nodes: [] },
      ]
    },
  ];

  $('#demo-tree').treeview({
    treeHeader: 'Chart of Accounts',
    data: data,
    collapseOnLoad: false,
  });
});
</script>

<style>
  .sec { margin-bottom: 56px; }
  .sec h2 { font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--g5); }
  .code-block { background: #161616; border-radius: 4px; overflow: auto; }
  .code-block pre { margin: 0; padding: 20px 24px; }
  .code-block code { font-family: var(--mono); font-size: 13px; color: #f5f5f5; line-height: 1.8; white-space: pre; }
  .demo-area { padding: 24px; border: 1px solid var(--g5); border-radius: 2px; background: var(--white); cursor: auto; min-height: 200px; }
</style>
