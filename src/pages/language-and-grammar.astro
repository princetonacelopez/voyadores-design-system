    font-size: 14px; font-weight: 500; color: var(--g2);
    line-height: 1.7; margin-bottom: 16px;
  }
  .sub-h3 {
    font-size: 14px; font-weight: 600; color: var(--black);
    margin-bottom: 12px;
  }
  .sub-note {
    font-size: 13px; font-weight: 500; color: var(--g2); margin-bottom: 12px;
  }

  /* Two-col layout */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .two-col h3 { font-size: 14px; font-weight: 600; color: var(--black); margin-bottom: 12px; }

  /* Brand attributes */
  .attr-list { display: flex; flex-direction: column; gap: 0; }
  .attr { padding: 12px 0; border-bottom: 1px solid var(--g5); }
  .attr:first-child { border-top: 1px solid var(--g5); }
  .attr-label { display: block; font-size: 13px; font-weight: 600; color: var(--black); margin-bottom: 2px; }
  .attr-desc  { display: block; font-size: 13px; font-weight: 400; color: var(--g2); line-height: 1.6; }

  /* Writing principles */
  .principles { display: flex; flex-direction: column; gap: 0; }
  .principle-card {
    display: grid; grid-template-columns: 32px 1fr;
    gap: 16px; padding: 20px 0; border-bottom: 1px solid var(--g5);
