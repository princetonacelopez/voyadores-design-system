  }
  .mc-label { display: block; font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--g2); margin-bottom: 4px; }

  .template-block {
    background: #111; border-radius: 4px; padding: 8px 14px; margin-bottom: 8px;
  }
  .template-block code { font-family: var(--mono); font-size: 12px; color: #e8e8e8; }
  .tpl-label { display: block; font-size: 10px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: #666; margin-bottom: 4px; }

  /* Button labels table */
