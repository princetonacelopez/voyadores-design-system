  }
  .principle-card:first-child { border-top: 1px solid var(--g5); }
  .pc-num {
    font-size: 11px; font-weight: 600; font-family: var(--mono);
    color: var(--brand); padding-top: 2px;
  }
  .pc-body h3 { font-size: 14px; font-weight: 600; color: var(--black); margin-bottom: 8px; }
