    font-family: var(--mono); font-size: 12.5px; color: var(--g1); line-height: 1.6;
  }

  /* Do/Don't */
  .do-dont { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--g5); border-radius: 4px; overflow: hidden; margin-bottom: 20px; }
  .do-dont--sm .dd-item { font-size: 12px; }
