---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Language and Grammar" activeSection="language-and-grammar">
  <PageHeader
    eyebrow="Language and Grammar"
    title="Language and Grammar"
    description="Writing standards, grammar rules, and microcopy patterns for Voyadores products. Version 1.0 — July 2025."
  />

  <!-- ═══════════════════════════════════════════ BRAND VOICE -->
  <section class="sec" id="brand-voice">
    <h2>Brand voice &amp; personality</h2>

    <div class="two-col">
      <div>
        <h3>Core brand attributes</h3>
        <div class="attr-list">
          <div class="attr">
            <span class="attr-label">Simple</span>
            <span class="attr-desc">Clear, straightforward communication that eliminates confusion.</span>
          </div>
          <div class="attr">
            <span class="attr-label">Modern</span>
            <span class="attr-desc">Contemporary language that feels current and accessible.</span>
          </div>
          <div class="attr">
            <span class="attr-label">Empowering</span>
            <span class="attr-desc">Inspiring confidence and action in MSME owners.</span>
          </div>
        </div>
      </div>
      <div>
        <h3>Voice characteristics</h3>
        <div class="attr-list">
          <div class="attr">
            <span class="attr-label">Conversational yet professional</span>
            <span class="attr-desc">Speak like a knowledgeable friend, not a corporate entity.</span>
          </div>
          <div class="attr">
            <span class="attr-label">Confident but humble</span>
            <span class="attr-desc">Assert expertise while staying approachable.</span>
          </div>
          <div class="attr">
            <span class="attr-label">Solution-focused</span>
            <span class="attr-desc">Always guide toward actionable outcomes.</span>
          </div>
          <div class="attr">
            <span class="attr-label">Culturally aware</span>
            <span class="attr-desc">Respectful of Filipino business culture and values.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ WRITING PRINCIPLES -->
  <section class="sec" id="writing-principles">
    <h2>Writing principles</h2>

    <div class="principles">
      <div class="principle-card">
        <span class="pc-num">1</span>
        <div class="pc-body">
          <h3>Clarity first</h3>
          <ul>
            <li>Use active voice whenever possible</li>
            <li>Keep sentences under 20 words</li>
            <li>Choose familiar words over complex alternatives</li>
            <li>Break up long paragraphs (max 3–4 sentences)</li>
          </ul>
        </div>
      </div>
      <div class="principle-card">
        <span class="pc-num">2</span>
        <div class="pc-body">
          <h3>Empowerment through language</h3>
          <ul>
            <li>Use "you can" instead of "you should"</li>
            <li>Focus on opportunities, not limitations</li>
            <li>Celebrate small wins and progress</li>
            <li>Frame challenges as growth opportunities</li>
          </ul>
        </div>
      </div>
      <div class="principle-card">
        <span class="pc-num">3</span>
        <div class="pc-body">
          <h3>Cultural sensitivity</h3>
          <ul>
            <li>Use inclusive language that respects diverse Filipino communities</li>
            <li>Acknowledge different business sizes and stages</li>
            <li>Avoid assumptions about technical knowledge</li>
            <li>Respect traditional business practices while introducing modern solutions</li>
          </ul>
        </div>
      </div>
    </div>

    <h3 class="sub-h3" style="margin-top:32px">Content hierarchy</h3>
    <div class="rule-table">
      <div class="rt-head"><span>Level</span><span>Purpose</span><span>Example</span></div>
      <div class="rt-row"><span>H1 — Primary headline</span><span>Bold, benefit-driven statement</span><span class="rt-ex">"Grow your business with smart digital tools"</span></div>
      <div class="rt-row"><span>H2 — Secondary headline</span><span>Supporting details or features</span><span class="rt-ex">"Track sales, manage inventory, connect with customers"</span></div>
      <div class="rt-row"><span>H3 — Tertiary headline</span><span>Specific features or sections</span><span class="rt-ex">"Real-time sales dashboard"</span></div>
      <div class="rt-row"><span>Lead paragraph</span><span>Hook readers with immediate value</span><span class="rt-ex">Opens with the most important information</span></div>
      <div class="rt-row"><span>Body text</span><span>Provide context and details</span><span class="rt-ex">Supports the lead with supporting information</span></div>
      <div class="rt-row"><span>CTA text</span><span>Clear, specific next steps</span><span class="rt-ex">"Generate your first report"</span></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ ADDRESSES -->
  <section class="sec" id="addresses">
    <h2>Addresses</h2>
    <p class="sec-intro">Standard format for Philippine addresses.</p>

    <div class="code-sample">
      <span class="cs-label">Format</span>
      <code>[Unit/Floor], [Building Name] [Street Number] [Street Name] Brgy. [Barangay Name], [City/Municipality] [Province], [ZIP Code]</code>
    </div>

    <div class="do-dont">
      <div class="dd-col dd-do">
        <div class="dd-head">Do</div>
        <div class="dd-item">
          Unit 301, Ortigas Center<br />
          123 Julia Vargas Avenue<br />
          Brgy. San Antonio, Pasig City<br />
          Metro Manila, 1605
        </div>
        <div class="dd-item">Use complete and properly capitalized address elements</div>
      </div>
      <div class="dd-col dd-dont">
        <div class="dd-head">Don't</div>
        <div class="dd-item">123 Julia Vargas Ave, Ortigas, Pasig, MM</div>
        <div class="dd-item">Use abbreviations or lowercase barangay/city names</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ CAPITALIZATION -->
  <section class="sec" id="capitalization">
    <h2>Capitalization</h2>

    <div class="cap-grid">
      <div class="cap-card">
        <div class="cap-badge cap-default">Sentence case</div>
        <p>Default for UI, buttons, messages, navigation, and labels. Lowercase except first word and proper nouns.</p>
        <div class="do-dont do-dont--sm">
          <div class="dd-col dd-do">
            <div class="dd-head">Do</div>
            <div class="dd-item">Add new employee</div>
            <div class="dd-item">Generate monthly report</div>
            <div class="dd-item">Password must be at least 8 characters</div>
          </div>
          <div class="dd-col dd-dont">
            <div class="dd-head">Don't</div>
            <div class="dd-item">Add New Employee</div>
            <div class="dd-item">GENERATE MONTHLY REPORT</div>
            <div class="dd-item">PASSWORD MUST BE AT LEAST 8 CHARACTERS</div>
          </div>
        </div>
      </div>

      <div class="cap-card">
        <div class="cap-badge cap-title">Title case</div>
        <p>Formal document titles, page titles, or major campaign headlines only.</p>
        <div class="do-dont do-dont--sm">
          <div class="dd-col dd-do">
            <div class="dd-head">Do</div>
            <div class="dd-item">Employee Handbook and Policies</div>
            <div class="dd-item">Annual Financial Report 2025</div>
            <div class="dd-item">Sales Receipts</div>
          </div>
          <div class="dd-col dd-dont">
            <div class="dd-head">Don't</div>
            <div class="dd-item">EMPLOYEE HANDBOOK AND POLICIES</div>
            <div class="dd-item">annual financial report 2025</div>
            <div class="dd-item">SALES RECEIPTs</div>
          </div>
        </div>
      </div>

      <div class="cap-card">
        <div class="cap-badge cap-all">ALL CAPS</div>
        <p>Only for acronyms and emergency alerts.</p>
        <div class="do-dont do-dont--sm">
          <div class="dd-col dd-do">
            <div class="dd-head">Do</div>
            <div class="dd-item">CEO, BIR, MSMEs, VAT</div>
            <div class="dd-item">CRITICAL: Maintenance in 5 minutes</div>
          </div>
          <div class="dd-col dd-dont">
            <div class="dd-head">Don't</div>
            <div class="dd-item">Ceo, Bir, msmes, Vat</div>
            <div class="dd-item">Critical: Maintenance in 5 minutes</div>
          </div>
        </div>
      </div>

      <div class="cap-card">
        <div class="cap-badge cap-lower">lowercase</div>
        <p>Emails, domains, file names, and technical terms.</p>
        <div class="do-dont do-dont--sm">
          <div class="dd-col dd-do">
            <div class="dd-head">Do</div>
            <div class="dd-item">support@voyadores.com</div>
            <div class="dd-item">invoice_template.pdf</div>
            <div class="dd-item">employee_id</div>
          </div>
          <div class="dd-col dd-dont">
            <div class="dd-head">Don't</div>
            <div class="dd-item">SUPPORT@VOYADORES.COM</div>
            <div class="dd-item">Invoice_Template.PDF</div>
            <div class="dd-item">Employee_ID</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ TIME & DATE -->
  <section class="sec" id="time-date">
    <h2>Time &amp; date</h2>

    <h3 class="sub-h3">Time format</h3>
    <ul class="rule-list">
      <li>Use <strong>12-hour format</strong> with AM/PM</li>
      <li>Use seconds only when needed (e.g., logs)</li>
      <li>Use "12:00 AM" / "12:00 PM" — not 00:00 / 24:00</li>
    </ul>
    <div class="do-dont" style="margin-bottom:32px">
      <div class="dd-col dd-do">
        <div class="dd-head">Do</div>
        <div class="dd-item">2:30 PM</div>
        <div class="dd-item">9:00 AM</div>
        <div class="dd-item">12:00 AM (midnight)</div>
        <div class="dd-item">2:30:45 PM (logs only)</div>
      </div>
      <div class="dd-col dd-dont">
        <div class="dd-head">Don't</div>
        <div class="dd-item">14:30</div>
        <div class="dd-item">9:00am</div>
        <div class="dd-item">00:00</div>
        <div class="dd-item">2:30 PM (when seconds are required)</div>
      </div>
    </div>

    <h3 class="sub-h3">Date format</h3>
    <div class="rule-table" style="margin-bottom:32px">
      <div class="rt-head"><span>Use in</span><span>Format</span><span>Example</span></div>
      <div class="rt-row"><span>System UI</span><span>MM/DD/YYYY</span><span class="rt-ex">06/15/2025</span></div>
      <div class="rt-row"><span>Marketing / docs</span><span>Long written</span><span class="rt-ex">June 15, 2025 or 15 June 2025</span></div>
      <div class="rt-row"><span>Logs (ISO format)</span><span>ISO 8601</span><span class="rt-ex">2025-06-15T14:30:00+08:00</span></div>
    </div>

    <h3 class="sub-h3">Days &amp; months</h3>
    <div class="rule-table" style="margin-bottom:32px">
      <div class="rt-head"><span>Full</span><span>3-letter (UI only)</span><span>Avoid</span></div>
      <div class="rt-row"><span>Monday</span><span>Mon</span><span class="rt-ex rt-avoid">M</span></div>
      <div class="rt-row"><span>January</span><span>Jan</span><span class="rt-ex rt-avoid">01</span></div>
    </div>

    <h3 class="sub-h3">Time durations</h3>
    <div class="rule-table" style="margin-bottom:32px">
      <div class="rt-head"><span>Unit</span><span>Body text</span><span>UI</span></div>
      <div class="rt-row"><span>5 seconds</span><span>"5 seconds left"</span><span class="rt-ex">"5 s"</span></div>
      <div class="rt-row"><span>30 minutes</span><span>"Complete this in 30 minutes"</span><span class="rt-ex">"30 min"</span></div>
      <div class="rt-row"><span>2 hours</span><span>"Expected wait: 2 hours"</span><span class="rt-ex">"2 h"</span></div>
      <div class="rt-row"><span>3 days</span><span>"We'll notify you in 3 days"</span><span class="rt-ex">"3 d"</span></div>
      <div class="rt-row"><span>2 weeks</span><span>"Trial period is 2 weeks"</span><span class="rt-ex">"2 wk"</span></div>
      <div class="rt-row"><span>6 months</span><span>"Contract lasts 6 months"</span><span class="rt-ex">"6 mo"</span></div>
    </div>

    <h3 class="sub-h3">Time &amp; date ranges</h3>
    <p class="sub-note">Use an en dash (–) with no spaces.</p>
    <div class="rule-table">
      <div class="rt-head"><span>Range type</span><span>Format</span><span>Example</span></div>
      <div class="rt-row"><span>Time</span><span>9:00 AM–5:00 PM</span><span class="rt-ex">Use in schedules</span></div>
      <div class="rt-row"><span>Date (same month)</span><span>June 15–20, 2025</span><span class="rt-ex">Billing period</span></div>
      <div class="rt-row"><span>Date (different month)</span><span>June 15–July 5, 2025</span><span class="rt-ex">Leave approval</span></div>
      <div class="rt-row"><span>Date (different year)</span><span>Dec 20, 2024–Jan 2, 2025</span><span class="rt-ex">Holiday closure</span></div>
      <div class="rt-row"><span>Timestamp</span><span>2025-06-15T14:30:00Z</span><span class="rt-ex">For logs</span></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ CURRENCY -->
  <section class="sec" id="currency">
    <h2>Currency &amp; numbers</h2>

    <h3 class="sub-h3">Currency</h3>
    <ul class="rule-list" style="margin-bottom:16px">
      <li>Use ₱ before the amount — not "PHP"</li>
      <li>Always include two decimal places when needed</li>
      <li>Use "to" for currency ranges (not a hyphen)</li>
    </ul>
    <div class="do-dont" style="margin-bottom:32px">
      <div class="dd-col dd-do">
        <div class="dd-head">Do</div>
        <div class="dd-item">₱1,500</div>
        <div class="dd-item">₱25.50</div>
        <div class="dd-item">₱500 to ₱1,000</div>
      </div>
      <div class="dd-col dd-dont">
        <div class="dd-head">Don't</div>
        <div class="dd-item">PHP 1500</div>
        <div class="dd-item">₱25.5</div>
        <div class="dd-item">₱500–₱1,000</div>
      </div>
    </div>

    <h3 class="sub-h3">Numbers &amp; numerals</h3>
    <div class="rule-table" style="margin-bottom:32px">
      <div class="rt-head"><span>Rule</span><span>Example</span></div>
      <div class="rt-row"><span>Spell out 1–9</span><span class="rt-ex">"three reports", "nine days"</span></div>
      <div class="rt-row"><span>Use numerals for 10+</span><span class="rt-ex">"15 users", "25 modules"</span></div>
      <div class="rt-row"><span>Always use numerals with units</span><span class="rt-ex">"3 kg", "5 minutes"</span></div>
      <div class="rt-row"><span>Spell out if starting a sentence</span><span class="rt-ex">"Twelve employees joined."</span></div>
      <div class="rt-row"><span>Use numerals in UI</span><span class="rt-ex">"Save 3 records", "Upload 12 files"</span></div>
    </div>

    <h3 class="sub-h3">Measurements &amp; units</h3>
    <p class="sub-note">Use metric units. Spell out in content; use abbreviations in UI or tables.</p>
    <div class="rule-table">
      <div class="rt-head"><span>Measurement</span><span>Body text</span><span>UI</span></div>
      <div class="rt-row"><span>Distance</span><span>10 kilometers</span><span class="rt-ex">10 km</span></div>
      <div class="rt-row"><span>Weight</span><span>5 kilograms</span><span class="rt-ex">5 kg</span></div>
      <div class="rt-row"><span>Storage</span><span>128 gigabytes</span><span class="rt-ex">128 GB</span></div>
      <div class="rt-row"><span>Resolution</span><span>1920 × 1080 pixels</span><span class="rt-ex">1920 px × 1080 px</span></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ PUNCTUATION -->
  <section class="sec" id="punctuation">
    <h2>Punctuation</h2>

    <div class="punct-grid">

      <div class="punct-card">
        <h3>Commas (,)</h3>
        <ul>
          <li><strong>Oxford comma:</strong> Always use in series — "Sales, inventory, and customer management"</li>
          <li><strong>Thousands separator:</strong> ₱1,500</li>
          <li><strong>Dates:</strong> "June 15, 2025"</li>
          <li><strong>Compound sentences:</strong> "Save your work, and then log out"</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Dashes</h3>
        <ul>
          <li><strong>En dash (–):</strong> Ranges — "Pages 15–30", "9:00 AM–5:00 PM", "January–March 2025". No spaces.</li>
          <li><strong>Em dash (—):</strong> Parenthetical statements — "The results—our best yet—exceeded expectations". No spaces in formal writing.</li>
          <li><strong>Hyphen (-):</strong> Compound words ("Co-owner", "Real-time"), prefixes ("Pre-launch"), phone numbers ("0917-123-4567"). Never use for ranges.</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Periods (.)</h3>
        <ul>
          <li>End complete sentences</li>
          <li>Omit in headings and UI labels</li>
          <li>Omit in bulleted lists with fragments</li>
          <li>Use in abbreviations: "Inc.", "Ltd.", "Corp."</li>
          <li>Decimal points: "₱1,250.50"</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Exclamation marks (!)</h3>
        <ul>
          <li>Use sparingly — only for genuine enthusiasm</li>
          <li><strong>Good uses:</strong> Welcome messages, success notifications</li>
          <li><strong>Avoid:</strong> Instructions, error messages, formal content</li>
          <li>Never use multiple: one is enough</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Ellipses (...)</h3>
        <ul>
          <li>Indicate truncation in UI when text is cut off</li>
          <li>Three dots with no spaces between</li>
          <li>Space before and after in body text sentences</li>
          <li>Avoid in formal content — use "and more" instead</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Apostrophes (')</h3>
        <ul>
          <li><strong>Possessives:</strong> "The business's growth" (singular); "Businesses' needs" (plural)</li>
          <li><strong>Contractions:</strong> Only in casual contexts</li>
          <li>Avoid contractions in error messages, official content, or logs</li>
          <li>Don't use for plurals — no "1990's"</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Colons (:)</h3>
        <ul>
          <li>Introduce lists or explanations</li>
          <li>Don't capitalize the word after a colon unless it's a proper noun</li>
          <li>Use in time: "2:30 PM"</li>
          <li>Ratios: "3:1 ratio"</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Parentheses ( )</h3>
        <ul>
          <li>Acronym definitions: "MSMEs (Micro, Small, and Medium Enterprises)"</li>
          <li>Examples: "Popular accounting software (QuickBooks, Xero)"</li>
          <li>Phone area codes: "(02) 8123-4567"</li>
          <li>Don't overuse — limit to maintain readability</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Slashes (/)</h3>
        <ul>
          <li><strong>Alternatives:</strong> "Employee/contractor status"</li>
          <li><strong>Dates:</strong> Acceptable in technical contexts — "06/15/2025"</li>
          <li><strong>Avoid "and/or"</strong> — choose one or rephrase</li>
        </ul>
      </div>

      <div class="punct-card">
        <h3>Semicolons (;)</h3>
        <ul>
          <li>Generally avoid — use periods or break into separate sentences</li>
          <li>Acceptable for complex series with internal commas</li>
          <li>"Our offices are in Manila; Cebu City; and Singapore"</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════ SPECIAL CHARACTERS -->
  <section class="sec" id="special-chars">
    <h2>Special characters</h2>

    <div class="rule-table">
      <div class="rt-head"><span>Symbol</span><span>Use</span><span>Example</span></div>
      <div class="rt-row"><span>@ (at symbol)</span><span>Email addresses and social handles</span><span class="rt-ex">support@voyadores.com · @VoyadoresOfficial</span></div>
      <div class="rt-row"><span># (hash)</span><span>Reference numbers and social media only</span><span class="rt-ex">Invoice #2025-001</span></div>
      <div class="rt-row"><span>% (percent)</span><span>Always use symbol, no space, en dash for ranges</span><span class="rt-ex">15% · 10%–15%</span></div>
      <div class="rt-row"><span>° (degree)</span><span>Temperature (no space) and angles</span><span class="rt-ex">25°C · 90° angle</span></div>
      <div class="rt-row"><span>| (vertical bar)</span><span>Separating navigation, breadcrumbs, options</span><span class="rt-ex">Home | Products | Contact</span></div>
      <div class="rt-row"><span>_ (underscore)</span><span>File names and database fields only</span><span class="rt-ex">employee_handbook.pdf · employee_id</span></div>
      <div class="rt-row"><span>* (asterisk)</span><span>Required form fields, footnotes</span><span class="rt-ex">First name *</span></div>
      <div class="rt-row"><span>&amp; (ampersand)</span><span>Acceptable in company names and space-constrained UI labels only</span><span class="rt-ex">Avoid in body text — use "and"</span></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ FORMATTING -->
  <section class="sec" id="formatting">
    <h2>Formatting guidelines</h2>

    <h3 class="sub-h3">Text emphasis</h3>
    <div class="rule-table" style="margin-bottom:32px">
      <div class="rt-head"><span>Style</span><span>Use for</span><span>Avoid</span></div>
      <div class="rt-row"><span><strong>Bold</strong></span><span>Key information, UI element names in instructions, warnings</span><span class="rt-ex">Entire sentences; overuse reduces impact</span></div>
      <div class="rt-row"><span><em>Italics</em></span><span>Emphasis on specific words, first-time terms, foreign words, product names</span><span class="rt-ex">Long passages</span></div>
      <div class="rt-row"><span><u>Underline</u></span><span>Hyperlinks only</span><span class="rt-ex">Decorative emphasis — confuses users with links</span></div>
      <div class="rt-row"><span><s>Strikethrough</s></span><span>Deleted content, price comparisons</span><span class="rt-ex">Formal content</span></div>
    </div>

    <h3 class="sub-h3">Headings</h3>
    <ul class="rule-list" style="margin-bottom:32px">
      <li>H1: One per page — main topic</li>
      <li>H2: Major sections; H3: Subsections; H4: Detailed breakdowns (use sparingly)</li>
      <li>Use sentence case — not title case</li>
      <li>No punctuation at the end of headings</li>
      <li>No bold, italics, or other emphasis inside heading tags</li>
    </ul>

    <h3 class="sub-h3">Lists</h3>
    <ul class="rule-list" style="margin-bottom:32px">
      <li>Use <strong>bullet lists</strong> for unordered items with parallel structure</li>
      <li>Use <strong>numbered lists</strong> for sequential steps or ranked items</li>
      <li>No periods if items are sentence fragments; use periods for complete sentences</li>
      <li>Maximum 7 items per list for readability</li>
    </ul>

    <h3 class="sub-h3">Links</h3>
    <div class="do-dont">
      <div class="dd-col dd-do">
        <div class="dd-head">Do</div>
        <div class="dd-item">Learn about inventory management</div>
        <div class="dd-item">Browse the help center</div>
        <div class="dd-item">Read the full study on Philippine business trends (external site)</div>
      </div>
      <div class="dd-col dd-dont">
        <div class="dd-head">Don't</div>
        <div class="dd-item">Click here</div>
        <div class="dd-item">Read more</div>
        <div class="dd-item">Visit our pricing page link</div>
      </div>
    </div>

    <h3 class="sub-h3" style="margin-top:32px">Code &amp; technical text</h3>
    <ul class="rule-list">
      <li>Use monospace / inline code for code snippets, file names, and field names</li>
      <li>Use code blocks for multi-line examples</li>
      <li>Example: <code>employee_data.csv</code>, <code>admin123</code></li>
    </ul>

    <h3 class="sub-h3" style="margin-top:32px">Truncation</h3>
    <ul class="rule-list">
      <li>Use ellipses (...) when text is cut off</li>
      <li>Truncate at meaningful points — don't cut words in half</li>
      <li>Always provide a way to see the full text (hover tooltip, expand, or separate page)</li>
    </ul>

    <div class="char-limits">
      <div class="cl-item"><span class="cl-label">Headlines (SEO)</span><span class="cl-val">60 characters</span></div>
      <div class="cl-item"><span class="cl-label">Meta descriptions</span><span class="cl-val">150–160 characters</span></div>
      <div class="cl-item"><span class="cl-label">Social media</span><span class="cl-val">Platform-specific limits</span></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════ ACCESSIBILITY -->
  <section class="sec" id="accessibility">
    <h2>Accessibility guidelines</h2>

    <div class="two-col">
      <div>
        <h3>Plain language</h3>
        <ul class="rule-list">
          <li>Write at 8th-grade reading level</li>
          <li>Define technical terms when first used</li>
          <li>Use familiar words over complex alternatives</li>
          <li>Break up long paragraphs into shorter chunks</li>
          <li>Active voice: "You can generate reports" vs "Reports can be generated"</li>
        </ul>
      </div>
      <div>
        <h3>Alt text for images</h3>
        <ul class="rule-list">
          <li>Describe purpose, not appearance: "Sales dashboard showing ₱50,000 revenue increase" not "Screenshot of graphs"</li>
          <li>Charts: Include key insights and trends</li>
          <li>Functional icons: Describe the action — "Edit employee details" not "Pencil icon"</li>
          <li>Decorative images: Use empty alt text (alt="")</li>
        </ul>
      </div>
    </div>

    <h3 class="sub-h3" style="margin-top:32px">Writing for screen readers</h3>
    <ul class="rule-list" style="margin-bottom:24px">
      <li>Write complete sentences — avoid fragments</li>
      <li>Spell out abbreviations on first use: "MSMEs (Micro, Small, and Medium Enterprises)"</li>
      <li>Avoid directional language: "In the section below" instead of "See below"</li>
      <li>Error messages: Be specific about what went wrong and how to fix it</li>
    </ul>

    <h3 class="sub-h3">Color and visual cues</h3>
    <ul class="rule-list">
      <li>Never rely on color alone — always provide text alternatives</li>
      <li>Status indicators: Use text, icons, or patterns alongside color</li>
      <li>Links: Identifiable without color (underlines, icons)</li>
    </ul>
  </section>

  <!-- ═════════════════════════════════════ MICROCOPY -->
  <section class="sec" id="microcopy">
    <h2>Components microcopy</h2>

    <div class="micro-grid">

      <!-- Tables -->
      <div class="micro-card">
        <h3><span class="mc-num">1</span> Table — long text</h3>
        <p class="mc-obj">Ensure readability of long text across the application.</p>
        <ul>
          <li>Truncate the text</li>
          <li>Use a tooltip to show the full content</li>
        </ul>
        <div class="mc-example">
          <span class="mc-label">Example</span>
          <span>Your session has expired due to inac…</span>
        </div>
      </div>

      <!-- Form Label -->
      <div class="micro-card">
        <h3><span class="mc-num">2</span> Form labels</h3>
        <p class="mc-obj">Consistent styling and clarity for form labels.</p>
        <ul>
          <li>Use sentence case</li>
          <li>Keep labels short and descriptive</li>
          <li>Use the <code>required</code> attribute for mandatory fields</li>
        </ul>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>First name · Date of completion</span>
        </div>
      </div>

      <!-- Placeholders -->
      <div class="micro-card">
        <h3><span class="mc-num">3</span> Placeholders</h3>
        <ul>
          <li><strong>Input field:</strong> Do not use a placeholder</li>
          <li><strong>Text area:</strong> Do not use a placeholder</li>
          <li><strong>Select field:</strong> Use sentence case — "Select a/an [form-label]" or "Filter by [form-label]"</li>
        </ul>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Select a customer · Filter by status</span>
        </div>
      </div>

      <!-- Error Messages -->
      <div class="micro-card">
        <h3><span class="mc-num">4</span> Error messages</h3>
        <p class="mc-obj">Guide users to complete the form.</p>
        <div class="template-block">
          <span class="tpl-label">Required field</span>
          <code>[Form-label] is a required field</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Address is a required field</span>
        </div>
        <div class="template-block" style="margin-top:12px">
          <span class="tpl-label">Context-based</span>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>We need this to ensure delivery reaches the correct location.<br />Start time should be entered in 12-hour format.<br />Add at least one invoice item.</span>
        </div>
      </div>

      <!-- Info labels -->
      <div class="micro-card">
        <h3><span class="mc-num">5</span> Info labels</h3>
        <p class="mc-obj">Clarify, explain, or provide helpful guidance about a form field.</p>
        <div class="template-block">
          <code>[Form-label] [purpose]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Address is where we'll send your physical documents.<br />Pay type refers to how employees are compensated for their work.</span>
        </div>
      </div>

      <!-- Modal confirmation -->
      <div class="micro-card">
        <h3><span class="mc-num">6</span> Modal — confirmation</h3>
        <div class="template-block">
          <span class="tpl-label">Header</span>
          <code>[Action verb] [subject]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Delete employee · Approve payroll adjustment</span>
        </div>
        <div class="template-block" style="margin-top:12px">
          <span class="tpl-label">Body</span>
          <code>&lt;Confirmation question&gt; &lt;Consequence&gt;</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Are you sure you want to delete this report? This will permanently remove it from your records.</span>
        </div>
      </div>

      <!-- Modal header -->
      <div class="micro-card">
        <h3><span class="mc-num">7</span> Modal header</h3>
        <div class="template-block">
          <code>[Action verb] [subject]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>View employee EMP-00040<br />Edit invoice #INV-00155</span>
        </div>
      </div>

      <!-- Link text -->
      <div class="micro-card">
        <h3><span class="mc-num">8</span> Link text</h3>
        <p class="mc-obj">Help users navigate or take secondary actions.</p>
        <ul>
          <li>Use sentence case</li>
          <li>Be descriptive — avoid "click here"</li>
          <li>Use concise, scannable phrases</li>
        </ul>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Read the full article<br />Learn more about Payroll Generation<br />Browse help center</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════ BUTTON LABELS -->
  <section class="sec" id="button-labels">
    <h2>Button labels</h2>

    <h3 class="sub-h3">Button text rules</h3>
    <ul class="rule-list" style="margin-bottom:24px">
      <li>Use sentence case</li>
      <li>Start with an action verb</li>
      <li>Be specific and concise</li>
      <li>Desktop: <code>[Action verb] [subject (optional)]</code> — Create, Update, Approve payroll</li>
      <li>Mobile action button: <code>[Action verb]</code> — Create, Update, Approve</li>
    </ul>

    <div class="btn-table">
      <div class="bt-head">
        <span>Label</span>
        <span>Definition</span>
        <span>Icon</span>
        <span>Confirms?</span>
      </div>
      {[
        ['Accept',     'Confirms a prompt, setting, or request—often implying agreement or consent.',    'check',               true ],
        ['Activate',   'Enables a feature or status. Counterpart of Deactivate.',                        'power-off',           true ],
        ['Add',        'Inserts an item into an existing set or structure. Lightweight and immediate.',   'plus',                false],
        ['Apply',      'Commits selected changes without leaving a form.',                                'star-magic',          true ],
        ['Approve',    'Grants permission to move a request forward in a workflow.',                      'like',                true ],
        ['Cancel',     'Stops an in-progress action or closes a modal without saving.',                   'ban',                 false],
        ['Close',      'Dismisses a screen or component without implying any action was taken.',           'times',               false],
        ['Create',     'Initiates and finalizes a new, standalone record or object.',                     'plus',                false],
        ['Deactivate', 'Disables a feature without deleting it. Often reversible.',                       'power-off',           true ],
        ['Decline',    'Explicitly rejects a pending request, ending its workflow.',                      'dislike',             true ],
        ['Delete',     'Permanently removes an item. Use only for irreversible actions.',                 'trash',               true ],
        ['Dismiss',    'Silently closes an element (alert, banner) without saving. No data changes.',     'times-circle',        false],
        ['Download',   'Transfers files from the system to the user\'s device.',                          'download',            false],
        ['Draft',      'Saves an unfinished version for future completion. Not final.',                   'pen-line',            false],
        ['Edit',       'Opens an existing record to modify its content.',                                 'pen',                 false],
        ['Export',     'Downloads system data in another format (CSV, Excel, PDF).',                      'upload',              false],
        ['Generate',   'Produces output (documents, reports, schedules) from existing inputs.',           'bolt',                false],
        ['Import',     'Uploads and integrates external data into the system.',                           'download',            false],
        ['Preview',    'Displays a non-editable version of content before confirming.',                   'file-text',           false],
        ['Reject',     'Denies a submission and may return the item for revision.',                       'ban',                 true ],
        ['Remove',     'Detaches an item from a list or relationship. Less final than Delete.',           'minus-circle',        true ],
        ['Save',       'Stores current progress without submitting for review.',                          'floppy-disk',         false],
        ['Send',       'Delivers a message or document to a recipient. Triggers a notification.',        'send',                true ],
        ['Submit',     'Finalizes and forwards a form to the next workflow step.',                        'send-right',          false],
        ['Update',     'Applies new or modified data to an existing item.',                               'rotate',              false],
        ['Upload',     'Transfers files from the user\'s device to the system.',                         'upload-alt',          false],
        ['View',       'Opens a record in read-only mode. No edits or actions expected.',                 'eye',                 false],
      ].map(([l, d, i, c]) => (
        <div class="bt-row">
          <span class="bt-label">{l}</span>
          <span class="bt-def">{d}</span>
          <span class="bt-icon"><code>vi-{i}</code></span>
          <span class:list={['bt-conf', c ? 'bt-yes' : 'bt-no']}>{c ? 'Yes' : 'No'}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════════════════════════════ NOTIFICATIONS -->
  <section class="sec" id="notifications">
    <h2>Notifications, states &amp; alerts</h2>

    <div class="notif-grid">

      <div class="notif-card nc-success">
        <h3>Success</h3>
        <p class="mc-obj">Reassure users that their action was successful.</p>
        <div class="template-block">
          <code>[Subject] has been successfully [action]. [Impact (optional)]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>Payroll has been successfully disbursed. Employees can now see their payslip.<br />Invoice has been successfully voided. The client will not be billed for this invoice.</span>
        </div>
      </div>

      <div class="notif-card nc-error">
        <h3>Error</h3>
        <p class="mc-obj">Communicate what went wrong and what the user can do about it.</p>
        <ul style="margin-bottom:10px">
          <li>Avoid blaming the user</li>
          <li>Avoid technical jargon</li>
          <li>Be specific about what failed</li>
        </ul>
        <div class="template-block">
          <code>[Subject] [action] was unsuccessful. [Reason]. [Resolution]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Example</span>
          <span>Payroll generation was unsuccessful. Review employees' attendance and try generating again.</span>
        </div>
      </div>

      <div class="notif-card nc-empty">
        <h3>Empty state</h3>
        <p class="mc-obj">Communicate that there is no content to show.</p>
        <ul style="margin-bottom:10px">
          <li>Use sentence case</li>
          <li>Avoid technical jargon</li>
          <li>Include helpful guidance</li>
        </ul>
        <div class="template-block">
          <code>No [subjects] were found. [Resolution (optional)]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>No invoices were found. Create an invoice to start tracking your billing.<br />No expenses were found. Add an expense to start tracking your spending.</span>
        </div>
      </div>

      <div class="notif-card nc-system">
        <h3>Error state</h3>
        <p class="mc-obj">Communicate that a system action or data retrieval has failed.</p>
        <ul style="margin-bottom:10px">
          <li>Avoid blaming the user</li>
          <li>Be specific about what failed</li>
          <li>Include resolution guidance</li>
        </ul>
        <div class="template-block">
          <code>[Problem]. [Resolution (optional)]</code>
        </div>
        <div class="mc-example">
          <span class="mc-label">Examples</span>
          <span>You don't have permission to access this page.<br />Access denied. Contact your admin to update permissions.</span>
        </div>
      </div>

    </div>

    <div class="version-note">
      This document should be reviewed and updated quarterly to ensure continued relevance and effectiveness for Voyadores' growing community.
      <span class="vn-version">Version 1.0 — July 2025</span>
    </div>
  </section>

</BaseLayout>

<style>
  /* Quick nav */
  .cg-nav {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-bottom: 64px; padding-bottom: 32px;
    border-bottom: 1px solid var(--g5);
  }
  .cn-link {
    font-size: 12px; font-weight: 500;
    padding: 5px 12px; border: 1px solid var(--g4);
    border-radius: 100px; color: var(--g1);
    transition: border-color .12s, color .12s;
  }
  .cn-link:hover { border-color: var(--brand); color: var(--brand); }

  /* Sections */
  .sec { margin-bottom: 72px; scroll-margin-top: 24px; }
  .sec h2 {
    font-size: 20px; font-weight: 500; letter-spacing: -.4px; color: var(--black);
    margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--g5);
  }
